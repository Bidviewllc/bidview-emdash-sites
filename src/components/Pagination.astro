---
export interface Props {
	currentPage: number;
	totalPages: number;
	baseUrl: string;
	/** Extra query params to preserve (e.g., { q: "dallas", specialization: "Tinnitus" }) */
	params?: Record<string, string>;
	/** Multi-value query params to preserve (e.g., { specialization: ["tinnitus","cochlear"] }) */
	multiParams?: Record<string, string[]>;
}

const { currentPage, totalPages, baseUrl, params = {}, multiParams = {} } = Astro.props;

function buildUrl(page: number) {
	const sp = new URLSearchParams(params);
	// Append multi-value params
	for (const [key, values] of Object.entries(multiParams)) {
		for (const v of values) {
			sp.append(key, v);
		}
	}
	if (page > 1) sp.set("page", String(page));
	const qs = sp.toString();
	return baseUrl + (qs ? "?" + qs : "");
}

const showPrev = currentPage > 1;
const showNext = currentPage < totalPages;

// Build page number array with ellipsis
const pages: (number | "...")[] = [];
for (let i = 1; i <= totalPages; i++) {
	if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
		pages.push(i);
	} else if (pages[pages.length - 1] !== "...") {
		pages.push("...");
	}
}
---

{totalPages > 1 && (
	<nav aria-label="Pagination" class="flex items-center justify-center gap-2 pt-12 pb-4">
		{showPrev ? (
			<a href={buildUrl(currentPage - 1)} class="flex items-center gap-1 px-4 h-12 rounded-lg border border-mist text-ink hover:border-primary hover:text-primary transition-colors font-medium">
				<span class="material-symbols-outlined text-sm">chevron_left</span>
				Previous
			</a>
		) : (
			<span class="flex items-center gap-1 px-4 h-12 rounded-lg border border-mist text-slate/40 cursor-not-allowed font-medium">
				<span class="material-symbols-outlined text-sm">chevron_left</span>
				Previous
			</span>
		)}

		{pages.map((p) =>
			p === "..." ? (
				<span class="px-2 text-slate">...</span>
			) : p === currentPage ? (
				<span class="flex items-center justify-center w-12 h-12 rounded-lg bg-primary text-white font-bold">{p}</span>
			) : (
				<a href={buildUrl(p)} class="flex items-center justify-center w-12 h-12 rounded-lg border border-mist text-ink hover:border-primary hover:text-primary transition-colors font-medium">{p}</a>
			)
		)}

		{showNext ? (
			<a href={buildUrl(currentPage + 1)} class="flex items-center gap-1 px-4 h-12 rounded-lg border border-mist text-ink hover:border-primary hover:text-primary transition-colors font-medium">
				Next
				<span class="material-symbols-outlined text-sm">chevron_right</span>
			</a>
		) : (
			<span class="flex items-center gap-1 px-4 h-12 rounded-lg border border-mist text-slate/40 cursor-not-allowed font-medium">
				Next
				<span class="material-symbols-outlined text-sm">chevron_right</span>
			</span>
		)}
	</nav>
)}
