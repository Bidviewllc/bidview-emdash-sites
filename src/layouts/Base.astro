				color: var(--text-dark);
			}
			.dropdown-all {
				grid-column: 1 / -1;
				color: var(--red);
				font-weight: 600;
				border-top: 1px solid var(--border);
				margin-top: 4px;
				padding-top: 12px;
				border-radius: 0;
