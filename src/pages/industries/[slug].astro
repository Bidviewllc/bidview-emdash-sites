		name: "Home Services & Plumbing",
		shortName: "Home Service Companies",
		image: "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=800&q=80",
		intro: [
			"When a pipe bursts in a Chicago basement at 2am or a homeowner discovers water damage after a storm, they search Google and call the first trusted result they find. Home services is a search-first industry — and businesses that aren't visible in local search are simply not getting those calls.",
			"The Chicago Marketing Agency builds digital marketing systems for plumbers, electricians, roofers, painters, landscapers, and all home service trades operating in Chicago and Chicagoland suburbs. We specialize in the unique marketing challenges of home services: seasonal demand, emergency calls, service area expansion, and the importance of online reputation.",
			"From Google Local Services Ads that generate verified leads in your service area to SEO strategies that build long-term organic traffic, we create marketing engines that keep your trucks rolling and your crews busy year-round."
		],
		services: [
			{ slug: "seo", name: "Home Services Local SEO", desc: "Dominate Google Maps and organic search for plumber, electrician, roofer, and trade-specific searches across Chicago neighborhoods." },
			{ slug: "paid-advertising", name: "Google LSA & Paid Ads", desc: "Google Local Services Ads with verified badge and targeted PPC campaigns that generate high-intent phone calls from homeowners in your service area." },
			{ slug: "web-design", name: "Trade Services Website", desc: "Mobile-first websites with click-to-call, service area pages, license display, and online estimate requests built to convert emergency searchers." },
			{ slug: "content-marketing", name: "Home Services Content", desc: "Service area pages, how-to guides, and seasonal content that capture homeowners at every stage of their research and buying journey." },
		],
		whyUs: [
			"Trade-specific marketing expertise: we understand the distinct customer journey for different home service trades and seasonal demand patterns",
			"Google Local Services Ads management including badge verification, review strategy, and lead dispute resolution",
			"Service area expansion strategy: we help growing home service companies add new ZIP codes and neighborhoods systematically",
			"Emergency service marketing: after-hours landing pages, call tracking, and urgency-focused messaging for emergency plumbing, electrical, and HVAC calls",
		],
		stats: [
			{ value: "4.8x", label: "Return on LSA investment" },
			{ value: "68%", label: "Increase in inbound call volume" },
			{ value: "41%", label: "Reduction in cost per job booked" },
			{ value: "190%", label: "Organic traffic growth in 12 months" },
		],
		schemaType: "HomeAndConstructionBusiness",
	},
};

const industry = industries[slug as string];
if (!industry) return Astro.redirect("/404");

const pageTitle = `${industry.name} Marketing Chicago | The Chicago Marketing Agency`;
const pageDesc = `Expert digital marketing for ${industry.name.toLowerCase()} in Chicago. SEO, web design, paid ads, and more — proven strategies that generate leads and grow revenue.`;
const siteUrl = "https://thechicagomarketingagency.vince-75c.workers.dev";
---

<Base title={pageTitle} description={pageDesc} image={industry.image}>
	<!-- ── JSON-LD SCHEMA ── -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Service",
		"name": `${industry.name} Marketing Chicago`,
		"description": pageDesc,
		"image": industry.image,
		"provider": {
			"@type": "MarketingAgency",
			"name": "The Chicago Marketing Agency",
			"url": siteUrl
		},
		"areaServed": {
			"@type": "City",
			"name": "Chicago",
			"sameAs": "https://www.wikidata.org/wiki/Q1297"
		},
		"audience": {
			"@type": industry.schemaType,
			"name": industry.name,
			"location": {
				"@type": "City",
				"name": "Chicago"
			}
		},
		"url": `${siteUrl}/industries/${slug}`
	})} />
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` },
			{ "@type": "ListItem", "position": 2, "name": "Industries", "item": `${siteUrl}/industries` },
			{ "@type": "ListItem", "position": 3, "name": industry.name, "item": `${siteUrl}/industries/${slug}` }
		]
	})} />

	<!-- ── HERO ── -->
	<section class="ind-hero">
		<div class="container ind-hero-inner">
			<div class="ind-hero-text">
				<nav class="breadcrumb" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span>/</span>
					<a href="/industries">Industries</a>
					<span>/</span>
					<span>{industry.name}</span>
				</nav>
				<span class="eyebrow">{industry.name}</span>
				<h1>Marketing for {industry.shortName} in Chicago</h1>
				<p class="ind-hero-desc">{industry.intro[0]}</p>
				<div class="ind-hero-actions">
					<a href="/free-seo-audit" class="btn btn-primary">Get a Free {industry.shortName} Marketing Audit →</a>
					<a href="/results" class="btn btn-outline-white">See Our Results</a>
				</div>
			</div>
			<div class="ind-hero-img">
				<img src={industry.image} alt={`${industry.name} marketing Chicago`} width="580" height="420" loading="eager" />
			</div>
		</div>
	</section>

	<!-- ── INTRO ── -->
	<section class="ind-intro">
		<div class="container ind-intro-inner">
			<div class="ind-intro-body">
				{industry.intro.slice(1).map((para) => (
					<p>{para}</p>
				))}
				{industry.blogSlug && (
					<p class="ind-guide-link">
						Want a deep dive? Read our complete <a href={`/blog/${industry.blogSlug}`}>{industry.blogLabel} →</a>
					</p>
				)}
			</div>
			<div class="ind-intro-stats">
				{industry.stats.map((stat) => (
					<div class="ind-stat">
						<span class="ind-stat-value">{stat.value}</span>
						<span class="ind-stat-label">{stat.label}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ── SERVICES ── -->
	<section class="ind-services">
		<div class="container">
			<p class="eyebrow" style="color: var(--red); display: block; text-align: center;">What We Do</p>
			<h2 class="ind-services-heading">Services for {industry.shortName}</h2>
			<div class="ind-services-grid">
				{industry.services.map((svc, i) => (
					<a href={`/services/${svc.slug}`} class={`ind-svc-card ${i % 2 === 0 ? "card-red" : "card-navy"}`}>
						<h3>{svc.name}</h3>
						<p>{svc.desc}</p>
						<span class="ind-svc-link">Explore service →</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- ── WHY US ── -->
	<section class="ind-why">
		<div class="container ind-why-inner">
			<div class="ind-why-header">
				<p class="eyebrow" style="color: var(--red);">Why Choose Us</p>
				<h2>Why Chicago {industry.shortName} Choose Us</h2>
				<p class="ind-why-sub">We don't just know marketing — we know your industry. Here's what makes our approach different.</p>
			</div>
			<ul class="ind-why-list">
				{industry.whyUs.map((point) => (
					<li class="ind-why-item">
						<span class="ind-why-check" aria-hidden="true">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="20 6 9 17 4 12"/>
							</svg>
						</span>
						<span>{point}</span>
					</li>
				))}
			</ul>
		</div>
	</section>

	<!-- ── RESULTS ── -->
	<section class="ind-results">
		<div class="container">
			<p class="eyebrow" style="color: var(--red); display: block; text-align: center;">Real Results</p>
			<h2 class="ind-results-heading">What Chicago {industry.shortName} Achieve With Us</h2>
			<div class="ind-results-grid">
				{industry.stats.map((stat) => (
					<div class="ind-result-card">
						<span class="ind-result-value">{stat.value}</span>
						<span class="ind-result-label">{stat.label}</span>
					</div>
				))}
			</div>
			<p class="ind-results-note">Results vary by client, market conditions, and starting baseline. These represent averages across our {industry.shortName.toLowerCase()} client portfolio.</p>
		</div>
	</section>

	<!-- ── CTA STRIP ── -->
	<section class="ind-cta-strip">
		<div class="container ind-cta-strip-inner">
			<p class="ind-cta-strip-text">Ready to grow your {industry.shortName.toLowerCase()} business in Chicago?</p>
			<a href="/free-seo-audit" class="btn btn-primary">Get My Free Marketing Audit →</a>
		</div>
	</section>

	<!-- ── FINAL CTA ── -->
	<section class="ind-cta">
		<div class="container ind-cta-inner">
			<h2>Get a Free {industry.shortName} Marketing Audit</h2>
			<p>We'll analyze your current online presence, identify your biggest opportunities, and show you exactly how we'd grow your business — with no obligation.</p>
			<div class="ind-cta-actions">
				<a href="/free-seo-audit" class="btn btn-primary">Request My Free Audit →</a>
				<a href="/results" class="btn btn-outline-white">View Case Studies</a>
			</div>
		</div>
	</section>
</Base>

<style>
/* ── HERO ── */
.ind-hero {
	background: var(--navy);
	padding: 64px 0 72px;
}

.ind-hero-inner {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 48px;
	align-items: center;
}

.breadcrumb {
	display: flex;
	align-items: center;
	gap: 8px;
	font-size: 0.8125rem;
	color: rgba(255,255,255,0.5);
	margin-bottom: 24px;
}

.breadcrumb a {
	color: rgba(255,255,255,0.5);
	transition: color var(--transition);
}

.breadcrumb a:hover { color: rgba(255,255,255,0.8); }
.breadcrumb span:last-child { color: rgba(255,255,255,0.7); }

.ind-hero-text h1 {
	font-size: clamp(2rem, 4vw, 3rem);
	font-weight: 900;
	color: var(--white);
	line-height: 1.1;
	letter-spacing: -0.03em;
	margin-bottom: 20px;
}

.ind-hero-desc {
	font-size: 1.0625rem;
	color: rgba(255,255,255,0.7);
	line-height: 1.7;
	margin-bottom: 32px;
	max-width: 480px;
}

.ind-hero-actions {
	display: flex;
	gap: 12px;
	flex-wrap: wrap;
}

.ind-hero-img {
	display: flex;
	align-items: flex-end;
	justify-content: center;
}

.ind-hero-img img {
	width: 100%;
	max-width: 500px;
	height: 380px;
	object-fit: cover;
	border-radius: var(--radius-lg);
}

/* ── INTRO ── */
.ind-intro {
	padding: 72px 0;
	background: var(--white);
}

.ind-intro-inner {
	display: grid;
	grid-template-columns: 1fr auto;
	gap: 64px;
	align-items: start;
}

.ind-intro-body p {
	font-size: 1rem;
	color: var(--text-muted);
	line-height: 1.8;
	margin-bottom: 20px;
}

.ind-intro-body p:last-child { margin-bottom: 0; }

.ind-guide-link {
	margin-top: 24px;
	font-size: 0.9375rem;
	color: var(--text-muted);
}

.ind-guide-link a {
	color: var(--red);
	font-weight: 600;
	text-decoration: underline;
	text-underline-offset: 2px;
}

.ind-intro-stats {
	display: flex;
	flex-direction: column;
	gap: 32px;
	flex-shrink: 0;
	min-width: 200px;
}

.ind-stat {
	display: flex;
	flex-direction: column;
	align-items: center;
	text-align: center;
	padding: 24px 20px;
	background: var(--off-white);
	border-radius: var(--radius-lg);
	border: 1px solid var(--border);
}

.ind-stat-value {
	font-size: 2rem;
	font-weight: 900;
	color: var(--red);
	letter-spacing: -0.04em;
	line-height: 1;
	margin-bottom: 8px;
}

.ind-stat-label {
	font-size: 0.75rem;
	color: var(--text-muted);
	line-height: 1.4;
	font-weight: 500;
}

/* ── SERVICES ── */
.ind-services {
	padding: 80px 0;
	background: var(--off-white);
}

.ind-services-heading {
	font-size: clamp(1.75rem, 3vw, 2.25rem);
	text-align: center;
	color: var(--text-dark);
	margin-bottom: 48px;
}

.ind-services-grid {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 20px;
}

.ind-svc-card {
	padding: 36px 32px;
	border-radius: var(--radius-lg);
	text-decoration: none;
	display: flex;
	flex-direction: column;
	gap: 12px;
	transition: transform var(--transition), box-shadow var(--transition);
}

.ind-svc-card:hover {
	transform: translateY(-2px);
	box-shadow: 0 12px 32px rgba(0,0,0,0.12);
}

.card-red {
	background: var(--red);
}

.card-navy {
	background: var(--navy);
}

.ind-svc-card h3 {
	font-size: 1.125rem;
	font-weight: 700;
	color: var(--white);
	letter-spacing: -0.02em;
}

.ind-svc-card p {
	font-size: 0.9375rem;
	color: rgba(255,255,255,0.75);
	line-height: 1.6;
	flex: 1;
}

.ind-svc-link {
	font-size: 0.875rem;
	font-weight: 600;
	color: rgba(255,255,255,0.9);
	margin-top: 4px;
}

/* ── WHY US ── */
.ind-why {
	padding: 80px 0;
	background: var(--white);
}

.ind-why-inner {
	display: grid;
	grid-template-columns: 340px 1fr;
	gap: 80px;
	align-items: start;
}

.ind-why-header h2 {
	font-size: clamp(1.5rem, 3vw, 2rem);
	color: var(--text-dark);
	margin-bottom: 16px;
	line-height: 1.2;
}

.ind-why-sub {
	font-size: 0.9375rem;
	color: var(--text-muted);
	line-height: 1.7;
}

.ind-why-list {
	list-style: none;
	display: flex;
	flex-direction: column;
	gap: 20px;
}

.ind-why-item {
	display: flex;
	align-items: flex-start;
	gap: 16px;
	font-size: 0.9375rem;
	color: var(--text-muted);
	line-height: 1.6;
}

.ind-why-check {
	flex-shrink: 0;
	width: 28px;
	height: 28px;
	background: var(--red);
	border-radius: 50%;
	display: flex;
	align-items: center;
	justify-content: center;
	margin-top: 2px;
}

/* ── RESULTS ── */
.ind-results {
	padding: 80px 0;
	background: var(--navy);
}

.ind-results-heading {
	font-size: clamp(1.75rem, 3vw, 2.25rem);
	text-align: center;
	color: var(--white);
	margin-bottom: 48px;
}

.ind-results-grid {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	gap: 24px;
	margin-bottom: 32px;
}

.ind-result-card {
	background: rgba(255,255,255,0.05);
	border: 1px solid rgba(255,255,255,0.1);
	border-radius: var(--radius-lg);
	padding: 36px 24px;
	display: flex;
	flex-direction: column;
	align-items: center;
	text-align: center;
	gap: 12px;
}

.ind-result-value {
	font-size: 2.5rem;
	font-weight: 900;
	color: var(--red);
	letter-spacing: -0.04em;
	line-height: 1;
}

.ind-result-label {
	font-size: 0.8125rem;
	color: rgba(255,255,255,0.6);
	line-height: 1.4;
}

.ind-results-note {
	text-align: center;
	font-size: 0.8125rem;
	color: rgba(255,255,255,0.35);
	max-width: 600px;
	margin: 0 auto;
}

/* ── CTA STRIP ── */
.ind-cta-strip {
	background: var(--red);
	padding: 24px 0;
}

.ind-cta-strip-inner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 24px;
	flex-wrap: wrap;
}

.ind-cta-strip-text {
	font-size: 1rem;
	font-weight: 600;
	color: rgba(255,255,255,0.9);
}

.ind-cta-strip .btn-primary {
	background: var(--white);
	color: var(--red);
	border-color: var(--white);
	white-space: nowrap;
	flex-shrink: 0;
}

.ind-cta-strip .btn-primary:hover {
	background: var(--off-white);
	border-color: var(--off-white);
}

/* ── FINAL CTA ── */
.ind-cta {
	background: var(--navy);
	border-top: 1px solid rgba(255,255,255,0.08);
	padding: 80px 0;
}

.ind-cta-inner {
	text-align: center;
	max-width: 600px;
	margin: 0 auto;
}

.ind-cta-inner h2 {
	font-size: clamp(1.75rem, 3vw, 2.5rem);
	color: var(--white);
	margin-bottom: 16px;
}

.ind-cta-inner p {
	font-size: 1rem;
	color: rgba(255,255,255,0.65);
	margin-bottom: 32px;
	line-height: 1.7;
}

.ind-cta-actions {
	display: flex;
	gap: 12px;
	justify-content: center;
	flex-wrap: wrap;
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
	.ind-results-grid {
		grid-template-columns: repeat(2, 1fr);
	}
	.ind-services-grid {
		grid-template-columns: 1fr;
	}
}

@media (max-width: 768px) {
	.ind-hero-inner {
		grid-template-columns: 1fr;
	}
	.ind-hero-img { display: none; }

	.ind-intro-inner {
		grid-template-columns: 1fr;
		gap: 40px;
	}
	.ind-intro-stats {
		flex-direction: row;
		flex-wrap: wrap;
		min-width: unset;
		justify-content: center;
	}
	.ind-stat {
		flex: 1;
		min-width: 140px;
	}

	.ind-why-inner {
		grid-template-columns: 1fr;
		gap: 40px;
	}

	.ind-results-grid {
		grid-template-columns: repeat(2, 1fr);
	}

	.ind-cta-strip-inner { flex-direction: column; text-align: center; }
	.ind-cta-actions { flex-direction: column; align-items: center; }
}

@media (max-width: 480px) {
	.ind-results-grid {
		grid-template-columns: 1fr 1fr;
		gap: 16px;
	}
	.ind-result-card {
		padding: 24px 16px;
	}
	.ind-result-value {
		font-size: 2rem;
	}
}
</style>
