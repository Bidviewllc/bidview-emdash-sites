---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";

export const cacheHint = 3600;

type PostData = {
	title: string;
	excerpt?: string;
	featured_image?: { src: string; alt: string };
};

type Post = { slug: string; data: PostData };

const { entries: rawPosts } = await getEmDashCollection("posts");
const allPosts = rawPosts as unknown as Post[];

const categories = [
	{ label: "All Posts", value: "all" },
	{ label: "SEO", value: "seo" },
	{ label: "Chicago Local", value: "chicago" },
	{ label: "Web Design", value: "web-design" },
	{ label: "Paid Ads", value: "paid-ads" },
	{ label: "Industry Guides", value: "industry" },
];

const publishDate = () => {
	const date = new Date();
	date.setDate(date.getDate() - Math.floor(Math.random() * 60));
	return date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
};
---

<Base
	title="Blog — Chicago Marketing Agency"
	description="SEO tips, marketing strategies, and local business growth guides — written for Chicago entrepreneurs and business owners."
>
	<!-- ── HERO ── -->
	<section class="blog-hero">
		<div class="container blog-hero-inner">
			<nav class="breadcrumb" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span>/</span>
				<span>Blog</span>
			</nav>
			<span class="eyebrow">Insights & Resources</span>
			<h1>The Chicago Marketing Blog</h1>
			<p>SEO tips, marketing strategies, and local business growth guides — written for Chicago entrepreneurs.</p>
		</div>
	</section>

	<!-- ── POSTS ── -->
	<section class="blog-posts">
		<div class="container">
			<!-- Category filters -->
			<div class="blog-filters">
				{categories.map((cat, i) => (
					<button class={`filter-btn ${i === 0 ? "active" : ""}`} data-filter={cat.value}>
						{cat.label}
					</button>
				))}
			</div>

			{allPosts.length > 0 ? (
				<div class="posts-grid">
					{allPosts.map((post) => {
						const pd = post.data;
						return (
							<a href={`/blog/${post.slug}`} class="post-card">
								{pd.featured_image ? (
									<div class="post-card-image">
										<img src={pd.featured_image?.src} alt={pd.featured_image?.alt || pd.title} width="400" height="220" loading="lazy" />
									</div>
								) : (
									<div class="post-card-image post-card-placeholder">
										<span>📝</span>
									</div>
								)}
								<div class="post-card-body">
									<span class="post-card-tag">SEO</span>
									<h2>{pd.title}</h2>
									{pd.excerpt && <p>{pd.excerpt}</p>}
									<div class="post-card-meta">
										<span>{publishDate()}</span>
										<span class="post-card-meta-sep">·</span>
										<span>8 min read</span>
									</div>
									<span class="post-card-cta">Read More →</span>
								</div>
							</a>
						);
					})}
				</div>
			) : (
				<div class="blog-empty">
					<p>No posts yet. Check back soon — we're publishing new guides every week.</p>
					<a href="/free-seo-audit" class="btn btn-primary">Get a Free SEO Audit While You Wait →</a>
				</div>
			)}
		</div>
	</section>

	<!-- ── EMAIL SIGNUP ── -->
	<section class="blog-subscribe">
		<div class="container blog-subscribe-inner">
			<h2>Get Free Marketing Insights Every Week</h2>
			<p>Join 2,400+ Chicago business owners getting actionable SEO and marketing tips straight to their inbox.</p>
			<form class="subscribe-form" action="/subscribe" method="POST">
				<input type="email" name="email" placeholder="Your email address" required />
				<button type="submit" class="btn btn-primary">Subscribe Free</button>
			</form>
			<p class="subscribe-note">No spam. Unsubscribe anytime.</p>
		</div>
	</section>
</Base>

<style>
/* ── HERO ── */
.blog-hero {
	padding: 56px 0 40px;
	background: var(--white);
	border-bottom: 1px solid var(--border);
}

.breadcrumb {
	display: flex;
	align-items: center;
	gap: 8px;
	font-size: 0.8125rem;
	color: var(--text-muted);
	margin-bottom: 16px;
}

.breadcrumb a {
	color: var(--text-muted);
	transition: color var(--transition);
}

.breadcrumb a:hover { color: var(--red); }

.blog-hero h1 {
	font-size: clamp(2rem, 4vw, 2.75rem);
	color: var(--text-dark);
	line-height: 1.1;
	margin-bottom: 12px;
}

.blog-hero p {
	font-size: 1.0625rem;
	color: var(--text-muted);
	max-width: 540px;
}

/* ── POSTS SECTION ── */
.blog-posts {
	padding: 56px 0 80px;
	background: var(--off-white);
}

/* ── FILTERS ── */
.blog-filters {
	display: flex;
	gap: 8px;
	flex-wrap: wrap;
	margin-bottom: 40px;
}

.filter-btn {
	font-family: var(--font);
	font-size: 0.875rem;
	font-weight: 500;
	color: var(--text-muted);
	background: var(--white);
	border: 1px solid var(--border);
	border-radius: 24px;
	padding: 10px 18px;
	min-height: 40px;
	cursor: pointer;
	transition: all var(--transition);
}

.filter-btn:hover,
.filter-btn.active {
	background: var(--text-dark);
	color: var(--white);
	border-color: var(--text-dark);
}

/* ── POSTS GRID ── */
.posts-grid {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 24px;
}

.post-card {
	background: var(--white);
	border: 1px solid var(--border);
	border-radius: var(--radius-lg);
	overflow: hidden;
	text-decoration: none;
	display: flex;
	flex-direction: column;
	transition: all var(--transition);
}

.post-card:hover {
	border-color: var(--red);
	transform: translateY(-2px);
	box-shadow: 0 8px 24px rgba(220,38,38,0.08);
}

.post-card-image {
	width: 100%;
	height: 220px;
	overflow: hidden;
	flex-shrink: 0;
}

.post-card-image img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	transition: transform 400ms ease;
}

.post-card:hover .post-card-image img {
	transform: scale(1.03);
}

.post-card-placeholder {
	background: var(--off-white);
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 2rem;
}

.post-card-body {
	padding: 24px;
	display: flex;
	flex-direction: column;
	flex: 1;
}

.post-card-tag {
	display: inline-block;
	font-size: 0.6875rem;
	font-weight: 700;
	letter-spacing: 0.08em;
	text-transform: uppercase;
	color: var(--red);
	margin-bottom: 10px;
}

.post-card h2 {
	font-size: 1rem;
	font-weight: 700;
	color: var(--text-dark);
	line-height: 1.35;
	margin-bottom: 10px;
	letter-spacing: -0.01em;
}

.post-card p {
	font-size: 0.875rem;
	color: var(--text-muted);
	line-height: 1.6;
	flex: 1;
	margin-bottom: 16px;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.post-card-meta {
	display: flex;
	align-items: center;
	gap: 6px;
	font-size: 0.8125rem;
	color: var(--text-light);
	margin-bottom: 12px;
}

.post-card-meta-sep { opacity: 0.5; }

.post-card-cta {
	font-size: 0.875rem;
	font-weight: 600;
	color: var(--red);
}

/* ── EMPTY STATE ── */
.blog-empty {
	text-align: center;
	padding: 80px 0;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 24px;
}

.blog-empty p {
	font-size: 1.125rem;
	color: var(--text-muted);
}

/* ── EMAIL SUBSCRIBE ── */
.blog-subscribe {
	background: var(--navy);
	padding: 64px 0;
}

.blog-subscribe-inner {
	text-align: center;
	max-width: 540px;
	margin: 0 auto;
}

.blog-subscribe h2 {
	font-size: clamp(1.5rem, 3vw, 2rem);
	color: var(--white);
	margin-bottom: 12px;
}

.blog-subscribe > .blog-subscribe-inner > p:first-of-type {
	font-size: 1rem;
	color: rgba(255,255,255,0.65);
	margin-bottom: 28px;
	line-height: 1.6;
}

.subscribe-form {
	display: flex;
	gap: 8px;
	max-width: 460px;
	margin: 0 auto 12px;
}

.subscribe-form input {
	flex: 1;
	padding: 12px 16px;
	font-family: var(--font);
	font-size: 0.9375rem;
	border: 1px solid rgba(255,255,255,0.2);
	border-radius: var(--radius);
	background: rgba(255,255,255,0.08);
	color: var(--white);
}

.subscribe-form input::placeholder { color: rgba(255,255,255,0.4); }
.subscribe-form input:focus {
	outline: none;
	border-color: rgba(255,255,255,0.5);
}

.subscribe-note {
	font-size: 0.8125rem;
	color: rgba(255,255,255,0.35);
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
	.posts-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 640px) {
	.posts-grid { grid-template-columns: 1fr; }
	.subscribe-form { flex-direction: column; }
}
</style>
