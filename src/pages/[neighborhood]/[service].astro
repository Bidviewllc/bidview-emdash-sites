---
import { getEmDashEntry } from "emdash";
import Base from "../../layouts/Base.astro";

export const cacheHint = 3600;

const { neighborhood, service } = Astro.params;

const { entry } = await getEmDashEntry("services", service as string);
if (!entry) return Astro.redirect("/404");

const d = entry.data as Record<string, any>;

// ── Neighborhood map: slug → { name, character } (fallback if no CMS entry) ──
const neighborhoods: Record<string, { name: string; character: string; nearby: string[] }> = {
	"lincoln-park": {
		name: "Lincoln Park",
		character: "one of Chicago's most affluent and competitive neighborhoods, where local boutiques, restaurants, and service businesses compete fiercely for an educated, high-income clientele",
		nearby: ["old-town", "lakeview", "bucktown", "wicker-park", "gold-coast", "uptown"],
	},
	"wicker-park": {
		name: "Wicker Park",
		character: "a creative, trend-setting neighborhood where independent businesses thrive on authenticity and where digital-savvy customers do their research before spending a dollar",
		nearby: ["bucktown", "ukrainian-village", "west-town", "logan-square", "avondale", "humboldt-park"],
	},
	"logan-square": {
		name: "Logan Square",
		character: "a rapidly evolving neighborhood where a mix of long-standing local businesses and new concepts compete for a diverse, digitally connected community",
		nearby: ["wicker-park", "bucktown", "avondale", "albany-park", "humboldt-park", "irving-park"],
	},
	"river-north": {
		name: "River North",
		character: "Chicago's densest restaurant and gallery district, where standing out online is not optional — it's the difference between packed tables and empty seats",
		nearby: ["the-loop", "west-loop", "gold-coast", "streeterville", "old-town", "lincoln-park"],
	},
	"the-loop": {
		name: "The Loop",
		character: "the commercial and financial heart of Chicago, where B2B companies and consumer brands alike need enterprise-level digital presence to compete for downtown foot traffic and corporate accounts",
		nearby: ["river-north", "west-loop", "south-loop", "streeterville", "gold-coast", "pilsen"],
	},
	"west-loop": {
		name: "West Loop",
		character: "Chicago's hottest growth corridor — a neighborhood that transformed from meatpacking to Michelin stars, and where businesses need marketing that matches that ambition",
		nearby: ["the-loop", "river-north", "pilsen", "little-italy", "ukrainian-village", "humboldt-park"],
	},
	"bucktown": {
		name: "Bucktown",
		character: "a neighborhood that blends creative culture with rising household incomes, where businesses need to speak to both the long-time locals and the newer, higher-spending residents",
		nearby: ["wicker-park", "logan-square", "lincoln-park", "ukrainian-village", "west-town", "avondale"],
	},
	"lakeview": {
		name: "Lakeview",
		character: "one of Chicago's most densely populated neighborhoods, with Wrigleyville at its core and thousands of residents who rely on Google and social media to discover local businesses",
		nearby: ["lincoln-park", "uptown", "andersonville", "ravenswood", "irving-park", "old-town"],
	},
	"old-town": {
		name: "Old Town",
		character: "a historic, walkable neighborhood where independent businesses thrive alongside major entertainment venues and where word-of-mouth starts online",
		nearby: ["lincoln-park", "river-north", "gold-coast", "lakeview", "wicker-park", "bucktown"],
	},
	"gold-coast": {
		name: "Gold Coast",
		character: "Chicago's premier luxury neighborhood, where high-net-worth residents expect premium experiences — and where your marketing needs to reflect that standard from the first impression",
		nearby: ["river-north", "old-town", "lincoln-park", "streeterville", "the-loop", "lakeview"],
	},
	"streeterville": {
		name: "Streeterville",
		character: "a neighborhood anchored by Northwestern hospital, Navy Pier, and Michigan Avenue — a high-traffic zone where healthcare providers, hospitality businesses, and retailers all compete for visitor attention",
		nearby: ["river-north", "gold-coast", "the-loop", "lincoln-park", "south-loop", "old-town"],
	},
	"hyde-park": {
		name: "Hyde Park",
		character: "an intellectually driven neighborhood on the South Side anchored by the University of Chicago, where businesses serve a highly educated, research-oriented community that reads reviews carefully",
		nearby: ["bronzeville", "south-loop", "bridgeport", "pilsen", "chinatown", "little-italy"],
	},
	"pilsen": {
		name: "Pilsen",
		character: "a vibrant arts and culture district with deep Mexican heritage, where authentic storytelling and community connection are essential to any effective marketing strategy",
		nearby: ["little-italy", "west-loop", "bridgeport", "chinatown", "south-loop", "the-loop"],
	},
	"bridgeport": {
		name: "Bridgeport",
		character: "a close-knit South Side neighborhood with deep roots and a growing number of new businesses that need digital visibility to reach both loyal locals and new residents",
		nearby: ["pilsen", "chinatown", "south-loop", "hyde-park", "bronzeville", "little-italy"],
	},
	"andersonville": {
		name: "Andersonville",
		character: "a neighborhood known for its fierce support of independent businesses and its community-first ethos — where buyers actively seek out locally owned shops and where authentic marketing wins",
		nearby: ["edgewater", "uptown", "ravenswood", "rogers-park", "lakeview", "lincoln-square"],
	},
	"uptown": {
		name: "Uptown",
		character: "a diverse, rapidly changing neighborhood where a new wave of businesses is establishing itself alongside long-standing institutions — and where digital presence is driving that transformation",
		nearby: ["andersonville", "edgewater", "lakeview", "ravenswood", "lincoln-square", "rogers-park"],
	},
	"edgewater": {
		name: "Edgewater",
		character: "a lakefront neighborhood that balances a relaxed residential feel with a growing dining and retail scene, attracting customers who plan their local outings based on online research",
		nearby: ["andersonville", "uptown", "rogers-park", "ravenswood", "lakeview", "lincoln-square"],
	},
	"rogers-park": {
		name: "Rogers Park",
		character: "Chicago's most diverse neighborhood, where multilingual communities, artists, and activists intersect — and where culturally aware, community-driven marketing cuts through the noise",
		nearby: ["edgewater", "andersonville", "uptown", "albany-park", "ravenswood", "lincoln-square"],
	},
	"ravenswood": {
		name: "Ravenswood",
		character: "a neighborhood of makers, manufacturers, and small business owners who are discovering the power of digital marketing to expand beyond their immediate community",
		nearby: ["lincoln-square", "andersonville", "albany-park", "irving-park", "lakeview", "uptown"],
	},
	"lincoln-square": {
		name: "Lincoln Square",
		character: "a neighborhood with a strong European heritage and a thriving small business community where authenticity and local identity are marketing assets, not afterthoughts",
		nearby: ["ravenswood", "andersonville", "albany-park", "irving-park", "avondale", "lakeview"],
	},
	"albany-park": {
		name: "Albany Park",
		character: "one of Chicago's most culturally diverse neighborhoods, where a kaleidoscope of immigrant-owned businesses serves a community that spans dozens of languages and backgrounds",
		nearby: ["ravenswood", "lincoln-square", "irving-park", "avondale", "logan-square", "andersonville"],
	},
	"irving-park": {
		name: "Irving Park",
		character: "a neighborhood in transition — established bungalow-belt roots meeting a new generation of businesses that need digital marketing to attract younger, mobile-first customers",
		nearby: ["albany-park", "avondale", "logan-square", "ravenswood", "lincoln-square", "lakeview"],
	},
	"avondale": {
		name: "Avondale",
		character: "a working-class neighborhood that has quietly become one of Chicago's most interesting food and creative scenes, where businesses benefit enormously from digital exposure to a city-wide audience",
		nearby: ["logan-square", "irving-park", "albany-park", "bucktown", "wicker-park", "humboldt-park"],
	},
	"humboldt-park": {
		name: "Humboldt Park",
		character: "a neighborhood with Puerto Rican cultural roots and a passionate local community, where businesses that invest in authentic, community-centered marketing build lasting loyalty",
		nearby: ["ukrainian-village", "west-town", "logan-square", "avondale", "wicker-park", "albany-park"],
	},
	"ukrainian-village": {
		name: "Ukrainian Village",
		character: "a tight-knit residential neighborhood with an increasingly vibrant commercial strip, where thoughtful digital marketing helps businesses punch well above their size",
		nearby: ["west-town", "wicker-park", "bucktown", "humboldt-park", "west-loop", "logan-square"],
	},
	"west-town": {
		name: "West Town",
		character: "a broad neighborhood that captures several of Chicago's most creative and entrepreneurial corridors, where businesses compete for customers who value quality and discovery",
		nearby: ["ukrainian-village", "wicker-park", "bucktown", "humboldt-park", "river-north", "west-loop"],
	},
	"south-loop": {
		name: "South Loop",
		character: "a rapidly growing neighborhood south of the Loop, where thousands of new residents and a wave of new businesses are both arriving at the same time — and where establishing early digital visibility pays dividends for years",
		nearby: ["the-loop", "pilsen", "bronzeville", "chinatown", "bridgeport", "west-loop"],
	},
	"bronzeville": {
		name: "Bronzeville",
		character: "a historically significant South Side neighborhood undergoing genuine revitalization, where businesses that tell their story well attract customers from across the city",
		nearby: ["south-loop", "hyde-park", "bridgeport", "pilsen", "chinatown", "the-loop"],
	},
	"chinatown": {
		name: "Chinatown",
		character: "a vibrant, destination neighborhood where restaurants, shops, and service businesses draw visitors from across the Chicago metro — and where multilingual, culturally attuned marketing opens doors",
		nearby: ["bridgeport", "pilsen", "south-loop", "bronzeville", "little-italy", "the-loop"],
	},
	"little-italy": {
		name: "Little Italy",
		character: "a historic neighborhood defined by its culinary heritage and university adjacency, where businesses benefit from connecting with both loyal long-time community members and the constant influx of UIC students and medical professionals",
		nearby: ["pilsen", "west-loop", "chinatown", "bridgeport", "south-loop", "the-loop"],
	},
};

// ── Neighborhood hero images (Unsplash) ──────────────────────────────────────
const neighborhoodImages: Record<string, string> = {
	// Named unique images
	"lincoln-park":      "photo-1494522855154-9297ac14b55f",
	"wicker-park":       "photo-1513635269975-59663e0ac1ad",
	"logan-square":      "photo-1449824913935-59a10b8d2000",
	"river-north":       "photo-1477959858617-67f85cf4f1df",
	"the-loop":          "photo-1581373449483-37449f962b6c",
	"west-loop":         "photo-1494891848038-7bd202a2afeb",
	"bucktown":          "photo-1513635269975-59663e0ac1ad",
	"lakeview":          "photo-1494522855154-9297ac14b55f",
	"old-town":          "photo-1449824913935-59a10b8d2000",
	"gold-coast":        "photo-1477959858617-67f85cf4f1df",
	// Chicago skyline fallback for remaining neighborhoods
	"streeterville":     "photo-1477959858617-67f85cf4f1df",
	"hyde-park":         "photo-1477959858617-67f85cf4f1df",
	"pilsen":            "photo-1477959858617-67f85cf4f1df",
	"bridgeport":        "photo-1477959858617-67f85cf4f1df",
	"andersonville":     "photo-1477959858617-67f85cf4f1df",
	"uptown":            "photo-1477959858617-67f85cf4f1df",
	"edgewater":         "photo-1477959858617-67f85cf4f1df",
	"rogers-park":       "photo-1477959858617-67f85cf4f1df",
	"ravenswood":        "photo-1477959858617-67f85cf4f1df",
	"lincoln-square":    "photo-1477959858617-67f85cf4f1df",
	"albany-park":       "photo-1477959858617-67f85cf4f1df",
	"irving-park":       "photo-1477959858617-67f85cf4f1df",
	"avondale":          "photo-1477959858617-67f85cf4f1df",
	"humboldt-park":     "photo-1477959858617-67f85cf4f1df",
	"ukrainian-village": "photo-1477959858617-67f85cf4f1df",
	"west-town":         "photo-1477959858617-67f85cf4f1df",
	"south-loop":        "photo-1477959858617-67f85cf4f1df",
	"bronzeville":       "photo-1477959858617-67f85cf4f1df",
	"chinatown":         "photo-1477959858617-67f85cf4f1df",
	"little-italy":      "photo-1477959858617-67f85cf4f1df",
};
const heroPhotoId = neighborhoodImages[neighborhood as string] ?? "photo-1477959858617-67f85cf4f1df";
const heroImageUrl = `https://images.unsplash.com/${heroPhotoId}?w=800&q=80`;

const { entry: areaEntry } = await getEmDashEntry("service_areas", neighborhood as string);

let neighborhoodName: string;
let neighborhoodCharacter: string;
let nearbyNeighborhoods: { slug: string; name: string }[];

if (areaEntry) {
	const ad = areaEntry.data as Record<string, any>;
	neighborhoodName = ad.title as string;
	neighborhoodCharacter = (ad.character as string) || "";
	let nearbySlugsCms: string[] = [];
	if (ad.nearby_json) {
		try { nearbySlugsCms = JSON.parse(ad.nearby_json); } catch { nearbySlugsCms = []; }
	}
	nearbyNeighborhoods = nearbySlugsCms
		.slice(0, 6)
		.map((slug: string) => ({
			slug,
			name: neighborhoods[slug]?.name ?? slug.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase()),
		}));
} else {
	const neighborhoodData = neighborhoods[neighborhood as string];
	if (!neighborhoodData) return Astro.redirect("/404");
	neighborhoodName = neighborhoodData.name;
	neighborhoodCharacter = neighborhoodData.character;
	nearbyNeighborhoods = neighborhoodData.nearby
		.filter((n) => neighborhoods[n])
		.slice(0, 6)
		.map((n) => ({ slug: n, name: neighborhoods[n].name }));
}

// ── Parse JSON fields ──────────────────────────────────────────────────────────
const parseJson = (val: any) => {
	if (!val) return [];
	if (Array.isArray(val)) return val;
	try { return JSON.parse(val); } catch { return []; }
};
const caseStudyStats = parseJson(d.case_study_stats_json);

const serviceTitle = d.title as string;
const pageTitle = `${serviceTitle} in ${neighborhoodName}, Chicago | The Chicago Marketing Agency`;
const pageDesc = `Expert ${serviceTitle.toLowerCase()} for ${neighborhoodName} businesses. The Chicago Marketing Agency helps local businesses in ${neighborhoodName} grow leads, rank higher, and convert more customers.`;

const baseUrl = "https://thechicagomarketingagency.com";

// ── Why-choose-us bullets (service-aware, neighborhood-aware) ─────────────────
const whyPoints = [
	`We know ${neighborhoodName} — we understand its competitive landscape, its customer demographics, and what it takes to win there.`,
	`Our ${serviceTitle.toLowerCase()} strategies are built around measurable revenue outcomes, not vanity metrics.`,
	`You get a dedicated point of contact who knows your neighborhood and reports results in plain language.`,
	`Every campaign is grounded in data: we audit what's already working in ${neighborhoodName} before building your strategy.`,
];
---

<Base title={pageTitle} description={pageDesc}>
	<!-- ── JSON-LD: Service + BreadcrumbList ── -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Service",
		"name": `${serviceTitle} in ${neighborhoodName}`,
		"description": pageDesc,
		"provider": {
			"@type": "MarketingAgency",
			"name": "The Chicago Marketing Agency",
			"url": baseUrl
		},
		"areaServed": {
			"@type": "Place",
			"name": `${neighborhoodName}, Chicago, IL`
		},
		"url": `${baseUrl}/${neighborhood}/${service}/`
	})} />
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Home", "item": `${baseUrl}/` },
			{ "@type": "ListItem", "position": 2, "name": neighborhoodName, "item": `${baseUrl}/${neighborhood}/` },
			{ "@type": "ListItem", "position": 3, "name": serviceTitle, "item": `${baseUrl}/${neighborhood}/${service}/` }
		]
	})} />

	<!-- ── HERO (split layout: text left / image right) ── -->
	<section class="nb-hero">
		<div class="container nb-hero-inner">
			<!-- Left: text content -->
			<div class="nb-hero-content">
				<nav class="breadcrumb" aria-label="Breadcrumb">
					<a href="/">Home</a>
					<span>/</span>
					<a href={`/${neighborhood}/`}>{neighborhoodName}</a>
					<span>/</span>
					<span>{serviceTitle}</span>
				</nav>
				<span class="eyebrow">{neighborhoodName}, Chicago</span>
				<h1>{serviceTitle} in {neighborhoodName}, Chicago</h1>
				<p class="nb-hero-desc">
					{neighborhoodName} is {neighborhoodCharacter}. We build {serviceTitle.toLowerCase()} strategies that match that reality and deliver results you can measure.
				</p>
				<div class="nb-hero-actions">
					<a href="/free-seo-audit/" class="btn btn-primary">Get a Free {serviceTitle} Audit →</a>
					<a href={`/services/${service}/`} class="btn btn-outline-white">About Our {serviceTitle}</a>
				</div>
			</div>
			<!-- Right: neighborhood image -->
			<div class="nb-hero-visual">
				<img
					src={heroImageUrl}
					alt={`${neighborhoodName} neighborhood, Chicago — ${serviceTitle}`}
					width="800"
					height="560"
					loading="eager"
				/>
			</div>
		</div>
	</section>

	<!-- ── LOCATION CONTENT ── -->
	<section class="nb-content">
		<div class="container nb-content-inner">
			<div class="nb-body">
				<h2>Why {serviceTitle} Matters More Than Ever in {neighborhoodName}</h2>
				<p>
					{neighborhoodName} businesses are not just competing with the shop next door — they're competing with every Google result, every Instagram ad, and every competitor who invested in their online presence before you did. {serviceTitle} is how you close that gap and start showing up where your customers are already looking.
				</p>
				<p>
					We've worked with businesses across Chicago neighborhoods, and {neighborhoodName} has its own distinct dynamics. The foot-traffic patterns are different. The customer acquisition costs vary by channel. The way people search for {serviceTitle.toLowerCase()} in {neighborhoodName} is shaped by the neighborhood's culture, its income profile, and how much competition already exists in your category. A cookie-cutter approach doesn't cut it here.
				</p>
				<p>
					Our approach starts with a deep audit of your current {serviceTitle.toLowerCase()} performance and a competitive analysis of the {neighborhoodName} market. From there, we build a strategy that matches your goals — whether that's driving more foot traffic, generating leads from the surrounding metro, or establishing the kind of digital authority that converts strangers into loyal customers.
				</p>
				<p>
					Chicago is a city of neighborhoods, and the best marketing respects that. When someone in {neighborhoodName} searches for what you offer, we want your business to be the obvious answer — not buried on page two while a competitor from across town takes your customer.
				</p>

				<!-- ── WHY CHOOSE US ── -->
				<div class="nb-why">
					<h3>Why Choose Us for {serviceTitle} in {neighborhoodName}</h3>
					<ul class="nb-why-list">
						{whyPoints.map((point) => (
							<li class="nb-why-item">
								<span class="nb-why-check" aria-hidden="true">✓</span>
								<span>{point}</span>
							</li>
						))}
					</ul>
				</div>
			</div>

			<!-- ── SIDEBAR CTA ── -->
			<aside class="nb-sidebar">
				<div class="nb-sidebar-card">
					<p class="nb-sidebar-eyebrow">Free Consultation</p>
					<h3>Ready to grow in {neighborhoodName}?</h3>
					<p>Tell us about your business and we'll map out a {serviceTitle.toLowerCase()} plan tailored for your neighborhood.</p>
					<a href="/free-seo-audit/" class="btn btn-primary nb-sidebar-btn">Get My Free Audit →</a>
					<a href="/contact/" class="nb-sidebar-link">Or talk to our team first</a>
				</div>
				<div class="nb-sidebar-meta">
					<div class="nb-meta-item">
						<span class="nb-meta-label">Service</span>
						<span class="nb-meta-value">{serviceTitle}</span>
					</div>
					<div class="nb-meta-item">
						<span class="nb-meta-label">Location</span>
						<span class="nb-meta-value">{neighborhoodName}, Chicago IL</span>
					</div>
					<div class="nb-meta-item">
						<span class="nb-meta-label">Agency</span>
						<span class="nb-meta-value">The Chicago Marketing Agency</span>
					</div>
				</div>
			</aside>
		</div>
	</section>

	<!-- ── STATS (if available from service entry) ── -->
	{caseStudyStats.length > 0 && (
		<section class="nb-stats">
			<div class="container">
				<p class="eyebrow" style="display: block; text-align: center; color: rgba(255,255,255,0.5); margin-bottom: 8px;">Proven Results</p>
				<h2 class="nb-stats-heading">What We Deliver for Chicago Businesses</h2>
				<div class="nb-stats-grid">
					{caseStudyStats.map((s: any) => (
						<div class="nb-stat">
							<span class="nb-stat-value">{s.value}</span>
							<span class="nb-stat-label">{s.label}</span>
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- ── CTA ── -->
	<section class="nb-cta">
		<div class="container nb-cta-inner">
			<div class="nb-cta-text">
				<h2>Get a Free {serviceTitle} Consultation in {neighborhoodName}</h2>
				<p>
					We'll review your current {serviceTitle.toLowerCase()} performance, show you exactly where the opportunities are in {neighborhoodName}, and walk you through a strategy with no commitment required.
				</p>
				<div class="nb-cta-actions">
					<a href="/free-seo-audit/" class="btn btn-primary">Start with a Free Audit →</a>
					<a href="/results/" class="btn btn-outline-white">See Our Results</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ── NEARBY NEIGHBORHOODS ── -->
	{nearbyNeighborhoods.length > 0 && (
		<section class="nb-nearby">
			<div class="container">
				<p class="eyebrow" style="color: var(--red); display: block; margin-bottom: 8px;">Other Areas We Serve</p>
				<h2 class="nb-nearby-heading">Other Neighborhoods We Serve with {serviceTitle}</h2>
				<div class="nb-nearby-grid">
					{nearbyNeighborhoods.map((n) => (
						<a href={`/${n.slug}/${service}/`} class="nb-nearby-card">
							<span class="nb-nearby-name">{n.name}</span>
							<span class="nb-nearby-label">{serviceTitle}</span>
							<span class="nb-nearby-arrow" aria-hidden="true">→</span>
						</a>
					))}
				</div>
				<p class="nb-nearby-all">
					Serving all 77 Chicago neighborhoods. <a href={`/services/${service}/`}>See our full {serviceTitle} offering →</a>
				</p>
			</div>
		</section>
	)}
</Base>

<style>
/* ── HERO (split grid) ── */
.nb-hero {
	background: var(--navy);
	padding: 64px 0 80px;
	overflow: hidden;
}

.nb-hero-inner {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 64px;
	align-items: center;
}

.nb-hero-content {
	display: flex;
	flex-direction: column;
}

.nb-hero-visual {
	border-radius: var(--radius-lg);
	overflow: hidden;
	min-height: 420px;
	position: relative;
}

.nb-hero-visual img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
	min-height: 420px;
}

.breadcrumb {
	display: flex;
	align-items: center;
	gap: 8px;
	font-size: 0.8125rem;
	color: rgba(255,255,255,0.45);
	margin-bottom: 28px;
	flex-wrap: wrap;
}

.breadcrumb a {
	color: rgba(255,255,255,0.45);
	transition: color var(--transition);
}

.breadcrumb a:hover { color: rgba(255,255,255,0.75); }
.breadcrumb span:last-child { color: rgba(255,255,255,0.65); }

.nb-hero h1 {
	font-size: clamp(1.75rem, 3.5vw, 2.875rem);
	font-weight: 900;
	color: var(--white);
	line-height: 1.08;
	letter-spacing: -0.035em;
	margin-bottom: 24px;
}

