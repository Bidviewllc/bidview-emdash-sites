			<p class="sa-unique-sub">Understanding the market is the foundation of every effective campaign we build for {neighborhoodName} businesses.</p>
			<div class="sa-unique-grid">
				{uniquePoints.map((point, i) => (
					<div class="sa-unique-card">
						<span class="sa-unique-num" aria-hidden="true">0{i + 1}</span>
