			<div class="sa-featured-grid">
				{featuredServices.map((svc) => (
					<div class="sa-featured-card">
						<h3 class="sa-featured-title">{svc.title}</h3>
						<p class="sa-featured-desc">{svc.description}</p>
						<a href={`/${neighborhood}/${svc.slug}/`} class="sa-featured-link">Learn more about {svc.title} in {neighborhoodName} →</a>
					</div>
