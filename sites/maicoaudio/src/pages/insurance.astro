---
import sharedHeaderRaw from "../../public/assets/partials/header.html?raw";
import sharedFooterRaw from "../../public/assets/partials/footer.html?raw";

export const prerender = false;
export const cacheHint = 3600;

function normalizeSharedPartialHtml(html: string): string {
	return html
		.replaceAll("Â©", "&copy;")
		.replaceAll('href="./"', 'href="/"')
		.replaceAll('src="../media/', 'src="/assets/media/')
		.replace(/(srcset=")([^"]*)"/g, (_match, prefix: string, value: string) => {
			const normalized = value
				.replace(/(^|,\s*)assets\/media\//g, "$1/assets/media/")
				.replace(/(^|,\s*)\.\.\/media\//g, "$1/assets/media/");
			return `${prefix}${normalized}"`;
		})
		.replace(
			/\s(href|src)="(?!https?:|mailto:|tel:|#|\/|data:)([^"]+)"/gi,
			(_match, attr: string, value: string) => ` ${attr}="/${value}"`,
		);
}

const sharedHeaderHtml = normalizeSharedPartialHtml(sharedHeaderRaw);
const sharedFooterHtml = normalizeSharedPartialHtml(sharedFooterRaw);
