<style>
	:root {
		--insurance-teal: #00a39a;
		--insurance-teal-dark: #06988f;
		--insurance-ink: #333333;
		--insurance-white: #ffffff;
	}

	.insurance-main,
	.insurance-main * {
		box-sizing: border-box;
	}

	.insurance-main {
		color: var(--insurance-ink);
		background: var(--insurance-white);
		font-family: "Montserrat", Arial, sans-serif;
		font-size: 16px;
		line-height: 1.5;
	}

	.insurance-main a {
		color: inherit;
		text-decoration: none;
	}

	.insurance-main img {
		display: block;
		max-width: 100%;
		height: auto;
	}

	.insurance-main button,
	.insurance-main input,
	.insurance-main select {
		font: inherit;
	}

	.page-hero {
		display: grid;
		place-items: center;
		min-height: 200px;
		color: var(--insurance-white);
		text-align: center;
		background:
			linear-gradient(rgba(0, 0, 0, 0.56), rgba(0, 0, 0, 0.56)),
			url("/assets/media/widex-hearing-aids-0901556acb.jpg") center 52% / cover no-repeat;
	}

	.page-hero__inner {
		width: min(100% - 20px, 1420px);
	}

	.breadcrumb {
		margin-bottom: 14px;
		font-size: 16px;
	}

	.page-hero h1 {
		margin: 0;
		color: var(--insurance-white);
		font-family: "Raleway", Arial, sans-serif;
		font-size: 54px;
		font-weight: 700;
		line-height: 1;
	}

	.content-wrap {
		width: min(100% - 40px, 980px);
		margin: 0 auto;
	}

	.intro-section {
		padding: 89px 0 100px;
	}

	.intro-section h2,
	.benefits-section h2 {
		margin: 0 0 17px;
		font-family: "Raleway", Arial, sans-serif;
		font-size: 32px;
		font-weight: 600;
		line-height: 1.2;
	}

	.intro-section p {
		margin: 0 0 14px;
	}

	.intro-section strong {
		font-weight: 700;
	}

	.insurance-card {
		width: 800px;
		margin-top: 35px;
		border-radius: 24px;
	}

	.benefits-section {
		padding: 90px 0 98px;
		color: var(--insurance-white);
		background: var(--insurance-teal);
	}

	.benefits-section h2 {
		margin-bottom: 52px;
		color: var(--insurance-white);
		line-height: 1;
	}

	.form-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 20px 16px;
	}

	.field {
		display: block;
		grid-column: 1 / -1;
	}

	.field-half {
		grid-column: span 1;
	}

	.field-date {
		width: 196px;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.benefits-form input,
	.benefits-form select {
		width: 100%;
		height: 38px;
		border: 1px solid #bfc7c9;
		border-radius: 0;
		color: #112337;
		background: var(--insurance-white);
		font-size: 14px;
		line-height: 38px;
		padding: 0 12px;
	}

	.benefits-form select {
		appearance: auto;
		padding-right: 32px;
	}

	.benefits-form input::placeholder {
		color: #5e6c73;
		opacity: 1;
	}

	.captcha-space {
		height: 122px;
	}

	.submit-button {
		min-width: 147px;
		min-height: 48px;
		border: 1px solid rgba(255, 255, 255, 0.9);
		border-radius: 6px;
		color: var(--insurance-white);
		background: transparent;
		font-size: 16px;
		font-weight: 700;
		text-transform: uppercase;
		cursor: pointer;
	}

	.submit-button:hover,
	.submit-button:focus-visible {
		background: var(--insurance-teal-dark);
	}

	.photo-section {
		padding: 84px 20px 80px;
		background: var(--insurance-white);
	}

	.photo-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 40px;
		max-width: 1400px;
		margin: 0 auto;
	}

	.photo-grid img {
		width: 100%;
		aspect-ratio: 1024 / 683;
		object-fit: cover;
	}

	@media (max-width: 767px) {
		.page-hero {
			min-height: 200px;
		}

		.breadcrumb {
			margin-bottom: 12px;
		}

		.page-hero h1 {
			font-size: 24px;
		}

		.content-wrap {
			width: min(100% - 40px, 980px);
		}

		.intro-section {
			padding: 40px 0;
		}

		.intro-section h2 {
			font-size: 32px;
		}

		.insurance-card {
			width: 100%;
			margin-top: 29px;
			border-radius: 10px;
		}

		.benefits-section {
			padding: 35px 0 29px;
		}

		.benefits-section h2 {
			margin-bottom: 34px;
			font-size: 26px;
			line-height: 1.5;
		}

		.form-grid {
			grid-template-columns: 1fr;
			gap: 20px;
		}

		.field-half {
			grid-column: 1;
		}

		.field-date {
			width: 196px;
		}

		.captcha-space {
			height: 122px;
		}

		.photo-section {
			padding: 40px 20px 50px;
		}

		.photo-grid {
			grid-template-columns: 1fr;
			gap: 30px;
		}

		.photo-grid__secondary {
			width: calc(100% - 20px);
			margin: 0 auto;
		}
	}
</style>
