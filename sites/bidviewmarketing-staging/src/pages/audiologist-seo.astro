---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/service-page-template.css';

import raw from '../../Pages/service-page-template.html?raw';
const bodyMatch = raw.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
const bodyHtml = bodyMatch ? bodyMatch[1] : '';
const pageHtml = bodyHtml
  .replace(/<header class="site-header"[\s\S]*?<\/header>/i, '')
  .replace(/<footer class="site-footer"[\s\S]*?<\/footer>/i, '')
  .replace(/<script\s+src="\.\/service-page-template\.js"[^>]*><\/script>\s*$/i, '')
  .replace(/\uFEFF/g, '')
  .trim();
---
<BaseLayout
  title="Audiologist SEO Services: Be the Practice Patients Choose First"
  scriptSrc="/scripts/service-page-template.js"
>
  <SiteHeader />
  <Fragment set:html={pageHtml} />
  <SiteFooter />
</BaseLayout>
