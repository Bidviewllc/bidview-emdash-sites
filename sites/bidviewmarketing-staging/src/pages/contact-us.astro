---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../../Pages/internal-pages-custom.css';

import raw from '../../Pages/Contact Us.html?raw';
const bodyMatch = raw.match(/<body[^>]*>([\s\S]*?)<\/body>/i);
const bodyHtml = bodyMatch ? bodyMatch[1] : '';
const pageHtml = bodyHtml
  .replace(/<header class="site-header"[\s\S]*?<\/header>/i, '')
  .replace(/<footer class="site-footer"[\s\S]*?<\/footer>/i, '')
  .trim();
---
<BaseLayout title="Contact Us | Bidview Marketing">
  <SiteHeader />
  <Fragment set:html={pageHtml} />
  <SiteFooter />
</BaseLayout>
