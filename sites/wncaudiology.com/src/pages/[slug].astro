---
import Base from "../layouts/Base.astro";
import { getEmDashCollection } from "emdash";

export const cacheHint = 3600;

const { slug } = Astro.params;

const { entries } = await getEmDashCollection("blog_articles", { status: "published" });
const entry = entries.find(
	(e) => e.id === slug || e.data.slug_path === `/${slug}/`,
);

if (!entry) return new Response(null, { status: 404, statusText: "Not Found" });

const { data } = entry;

/* Load the HTML fragment via glob — avoids storing 100KB bodies in D1 */
const pages = import.meta.glob("../content/pages/*.html", {
	query: "?raw",
	import: "default",
});
const htmlFile = data.html_file || slug;
const loader = pages[`../content/pages/${htmlFile}.html`];
if (!loader) return new Response(null, { status: 404, statusText: "Not Found" });
const pageHtml = String(await loader());
---

<Base
	title={data.seo_title}
	description={data.seo_description}
	canonical={`https://wncaudiology.com${data.slug_path}`}
	bodyClass={data.body_class}
>
	<Fragment set:html={pageHtml} />
</Base>
