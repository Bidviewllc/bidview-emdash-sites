{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "raleighhearingandtinnituscenter-staging",
	"account_id": "239e9d015c7a3a39cdc2e9400312f553",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "raleighhearingandtinnituscenter-staging-db",
			"database_id": "fbf4e6c8-7eba-47d8-9876-17eed415fc50",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "raleighhearingandtinnituscenter-staging-media",
		},
	],
	// Worker Loader for plugin sandboxing
	"worker_loaders": [
		{
			"binding": "LOADER",
		},
	],
}
