---
/**
 * Short hero band for internal pages — background image, breadcrumb, title.
 * The site nav (Header.astro) overlays the top via Base.astro.
 */
interface Crumb {
	label: string;
	href?: string;
}
interface Props {
	title: string;
	breadcrumbs: Crumb[];
	image: string;
	/** Optional meta line shown centered directly below the title (e.g. blog post date + author). */
	meta?: string | null;
}
const { title, breadcrumbs, image, meta } = Astro.props;
---

<section class="page-hero" style={`--page-hero-img: url('${image}')`}>
	<div class="page-hero-content">
		<nav class="page-hero-crumbs" aria-label="Breadcrumb">
			{breadcrumbs.map((crumb, i) => (
				<span class="crumb">
					{crumb.href ? (
						<a href={crumb.href} class="crumb-link">{crumb.label}</a>
					) : (
						<span class="crumb-current" aria-current="page">{crumb.label}</span>
					)}
					{i < breadcrumbs.length - 1 && (
						<span class="crumb-sep" aria-hidden="true">&gt;</span>
					)}
				</span>
			))}
		</nav>
		<h1 class="page-hero-title">{title}</h1>
		{meta && <p class="page-hero-meta">{meta}</p>}
	</div>
</section>

<style>
	.page-hero {
		position: relative;
		/* same inset width as the homepage hero */
		width: min(calc(100% - 56px), 1400px);
		margin: 48px auto 0;
		min-height: 430px;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		align-items: center;
		/* top padding clears the absolute site nav */
		padding: 150px 1.5rem 52px;
		background-image:
			linear-gradient(180deg, rgba(0, 0, 0, 0) 45%, rgba(0, 0, 0, 0.82) 100%),
			var(--page-hero-img);
		background-size: cover;
		background-position: center;
		border-radius: 18px;
		overflow: hidden;
	}

	.page-hero-content {
		width: 100%;
		max-width: 1180px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
		text-align: center;
	}

	.page-hero-crumbs {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 8px;
		font-family: "Lato", sans-serif;
		font-size: 18px;
		font-weight: 700;
		text-transform: uppercase;
		line-height: 1.2;
		letter-spacing: 0.01em;
	}

	.crumb {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}

	.crumb-link {
		color: rgba(255, 255, 255, 0.75);
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.crumb-link:hover {
		color: #fff;
	}

	.crumb-current {
		color: #fff;
	}

	.crumb-sep {
		color: #fff;
		font-weight: 400;
	}

	.page-hero-title {
		margin: 0;
		font-family: "Merriweather", Georgia, "Times New Roman", serif;
		font-size: clamp(2rem, 4.6vw, 3.375rem);
		font-weight: 700;
		line-height: 1.2;
		letter-spacing: 0;
		color: #fff;
	}

	.page-hero-meta {
		margin: 4px 0 0;
		font-family: "Lato", sans-serif;
		font-size: 16px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: rgba(255, 255, 255, 0.92);
		text-align: center;
	}

	@media (max-width: 900px) {
		.page-hero {
			width: min(calc(100% - 32px), 1400px);
			margin-top: 20px;
			min-height: 300px;
			padding: 48px 1.25rem 36px;
			border-radius: 14px;
		}

		.page-hero-crumbs {
			font-size: 14px;
		}
	}
</style>
