---
/**
 * Services section — extracted verbatim from the homepage so internal
 * pages render the identical services carousel. Self-contained.
 */
import { getEmDashCollection } from "emdash";

const [{ entries: configs }, { entries: services }] = await Promise.all([
	getEmDashCollection("site_config", { limit: 1 }),
	getEmDashCollection("services"),
]);
const cfg: Record<string, any> = configs[0]?.data ?? {};

const fallbackImages: Record<string, string> = {
	evaluation: "/uploads/454a6991e526dce986ad698d24fbe50e622dd410.jpg",
	loss: "/uploads/987f9e696c6744d636bb6afb18b12cf000eaa426.jpg",
	wax: "/uploads/eed506fc51205e55275e3792962852d28e218d9a.jpg",
	tinnitus: "/uploads/f34a0d4f4c8eea750dd899ef83306ee874cbceb5.jpg",
};
const serviceImageFallbacks: Record<string, string> = {
	"Hearing Evaluations": fallbackImages.evaluation,
	"Hearing Loss Evaluation & Treatment": fallbackImages.loss,
	"Ear Wax Removal": fallbackImages.wax,
	"Tinnitus Evaluations & Treatment": fallbackImages.tinnitus,
};
const serviceImageSrc = (title: string) =>
	serviceImageFallbacks[title] ?? fallbackImages.evaluation;
const imageSrc = (image: { src?: string } | null | undefined, fallback: string) =>
	image?.src ?? fallback;

const serviceDescriptions: Record<string, string> = {
	"Hearing Evaluations":
		"We provide comprehensive hearing evaluations to give you a clear and accurate picture of your hearing health. Our testing process looks closely at how you hear different tones, pitches, and speech sounds, helping us identify the type and degree of hearing loss you may be experiencing. Because every individual's needs are unique, we take the time to explain your results, answer your questions, and guide you toward the best next steps.",
	"Hearing Loss Evaluation & Treatment":
		"We take the time to truly understand what you're experiencing and use advanced diagnostic tools to evaluate the health of your inner ear and auditory pathways. From there, we'll walk through your results together and recommend options tailored to your needs and lifestyle, helping you hear more naturally and communicate with confidence.",
	"Ear Wax Removal":
		"Excess ear wax can cause uncomfortable fullness, itching, and even temporary hearing loss, but the good news is, it's an easy fix. We offer safe, gentle removal using professional tools designed to protect your ears (no cotton swabs needed). If you're experiencing blockage, itching, or a sudden drop in hearing, relief can be quick and comfortable.",
	"Tinnitus Evaluations & Treatment":
		"Ringing, buzzing, or humming in the ears can be frustrating, distracting, and exhausting, and you're not alone. We take the time to understand how tinnitus is affecting your day-to-day life and perform a thorough evaluation to identify possible contributing factors, such as hearing changes, noise exposure, or stress. From there, we'll explore personalized, evidence-based options designed to help you find relief and feel more in control.",
};

const servicesSubtext =
	typeof cfg.services_subtext === "string" &&
	cfg.services_subtext.trim() &&
	!cfg.services_subtext.startsWith(
		"At Commonwealth Audiology, we provide hearing care to meet your every need.",
	)
		? cfg.services_subtext
		: "At Commonwealth Audiology, we believe hearing care is more than a purchase, it's a commitment to your well-being. We offer the following services to make sure you get the best hearing care in Georgetown, KY.";

const orderedServices = services.toSorted(
	(a, b) => Number(a.data.sort_order ?? 0) - Number(b.data.sort_order ?? 0),
);
const displayedServices = orderedServices.slice(0, 4);
---

{displayedServices.length > 0 && (
	<section class="services-section">
		<div class="container">
			<div class="section-header">
				<h2>{cfg.services_heading ?? "Audiology Services"}</h2>
				<p class="section-subtext">{servicesSubtext}</p>
			</div>
			<div class="services-carousel" data-services-carousel data-set-size={displayedServices.length}>
				<div class="cards-grid" data-services-slider>
					{[0, 1, 2, 3, 4].map((setIndex) =>
						displayedServices.map((svc) => (
							<div class={`service-card${setIndex !== 2 ? " card-dupe" : ""}`} aria-hidden={setIndex === 2 ? undefined : "true"}>
								<div class="card-img-wrap">
									<img src={imageSrc(svc.data.image, serviceImageSrc(svc.data.title))} alt={svc.data.image?.alt ?? svc.data.title} class="card-img" />
								</div>
								<div class="card-body">
									<h3 class="card-title">{svc.data.title}</h3>
									<p class="card-desc">{serviceDescriptions[svc.data.title] ?? svc.data.description}</p>
									{svc.data.link_url && <a href={svc.data.link_url} class="card-link" tabindex={setIndex === 2 ? undefined : "-1"}>LEARN MORE <span class="button-arrow" aria-hidden="true"></span></a>}
								</div>
							</div>
						)),
					)}
				</div>
			</div>
			<div class="services-controls">
				<button type="button" aria-label="Previous services" data-services-prev>
					<img src="/uploads/aerow-left.svg" alt="" class="services-arrow-icon" aria-hidden="true" />
				</button>
				<button type="button" aria-label="Next services" data-services-next>
					<img src="/uploads/aerwo-right.svg" alt="" class="services-arrow-icon" aria-hidden="true" />
				</button>
			</div>
		</div>
	</section>
)}

<script>
	// Services: full-bleed carousel that scrolls in an infinite loop.
	// The cards are rendered 3x; we keep the user parked in the middle
	// copy and silently jump by one set-width at the seams.
	document
		.querySelectorAll<HTMLElement>("[data-services-carousel]")
		.forEach((scroller) => {
			const slider = scroller.querySelector<HTMLElement>("[data-services-slider]");
			if (!slider) return;
			const perSet = Number(scroller.dataset.setSize || "0");
			if (perSet < 1) return;

			function cardWidth() {
				const card = slider!.querySelector<HTMLElement>(".service-card");
				return card ? card.getBoundingClientRect().width : 0;
			}
			function cardStep() {
				const w = cardWidth();
				if (!w) return scroller.clientWidth;
				const gap = parseFloat(getComputedStyle(slider!).gap || "0");
				return w + gap;
			}
			const setWidth = () => cardStep() * perSet;

			// 5 card-sets are rendered; park in set index 2 (the middle),
			// offset 30% of a card so the left-most card is cut ~30%.
			function recenter() {
				scroller.scrollLeft = setWidth() * 2 + cardWidth() * 0.3;
			}
			recenter();

			let ticking = false;
			scroller.addEventListener(
				"scroll",
				() => {
					if (ticking) return;
					ticking = true;
					requestAnimationFrame(() => {
						const sw = setWidth();
						// jump by one set-width at the seams — content is identical
						// so the loop is invisible.
						if (scroller.scrollLeft < sw * 1.5) scroller.scrollLeft += sw;
						else if (scroller.scrollLeft > sw * 3.5)
							scroller.scrollLeft -= sw;
						ticking = false;
					});
				},
				{ passive: true },
			);

			const section = scroller.closest(".services-section");
			const previous = section?.querySelector("[data-services-prev]");
			const next = section?.querySelector("[data-services-next]");
			previous?.addEventListener("click", () =>
				scroller.scrollBy({ left: -cardStep(), behavior: "smooth" }),
			);
			next?.addEventListener("click", () =>
				scroller.scrollBy({ left: cardStep(), behavior: "smooth" }),
			);

			let resizeTimer: ReturnType<typeof setTimeout>;
			window.addEventListener("resize", () => {
				clearTimeout(resizeTimer);
				resizeTimer = setTimeout(recenter, 150);
			});
		});
</script>

<style>
	.services-section {
		--brand: #0076ba;
		--brand-light: #e8f4fb;
	}

	.container {
		max-width: 1440px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.section-subtext {
		color: #555;
		max-width: 650px;
		margin: 0 auto;
		font-size: 1rem;
		line-height: 1.7;
	}

	.button-arrow {
		display: inline-block;
		width: 1rem;
		height: 0.6875rem;
		flex: 0 0 auto;
		background: currentColor;
		-webkit-mask: url("/uploads/right-aerow-button.svg") center / contain no-repeat;
		mask: url("/uploads/right-aerow-button.svg") center / contain no-repeat;
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
	}

	.service-card {
		background: #fff;
		overflow: hidden;
	}

	.card-img {
		transition: transform 0.3s;
	}

	.services-section {
		padding: 3.8rem 0 4.65rem !important;
		background: #fff !important;
		overflow: hidden;
	}

	.services-section .container {
		width: 100% !important;
		max-width: none !important;
		padding: 0 28px !important;
	}

	.services-section .section-header {
		max-width: 1120px;
		margin: 0 auto 2.65rem !important;
		text-align: center;
	}

	.services-section .section-header h2 {
		margin: 0 0 0.85rem !important;
		color: #0076ba !important;
		font-family: "Merriweather", Georgia, "Times New Roman", serif;
		font-size: 2.72rem !important;
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0 !important;
		white-space: nowrap;
	}

	.services-section .section-subtext {
		max-width: 820px !important;
		margin: 0 auto !important;
		color: #4d4d4d;
		font-size: 1rem !important;
		font-weight: 500;
		line-height: 1.32 !important;
	}

	.services-section .cards-grid {
		display: flex !important;
		gap: 1.85rem !important;
		width: max-content !important;
		max-width: none !important;
		margin: 0 !important;
		overflow: visible;
		padding: 0.3rem 0 1.1rem;
	}

	.services-carousel {
		width: 100vw;
		margin-left: calc(50% - 50vw);
		overflow-x: auto;
		overflow-y: hidden;
		scrollbar-width: none;
		-ms-overflow-style: none;
		padding: 0.35rem 0 0.75rem;
	}

	.services-carousel::-webkit-scrollbar {
		display: none;
	}

	/* Card width = (viewport - (n+1) gaps) / (n + 1.4) so the row shows
	   n full cards plus a 30%-cut card on each edge. Desktop: n = 3. */
	.services-section .service-card {
		display: flex;
		flex: 0 0 calc((100vw - 4 * 1.85rem) / 4.4);
		min-height: 0;
		flex-direction: column;
		overflow: hidden;
		border-radius: 14px !important;
		background: #fff;
		border: 1px solid rgba(0,0,0,0.035);
		box-shadow: 0 8px 16px rgba(0,0,0,0.09) !important;
		transform: none !important;
	}

	.services-section .service-card:hover {
		transform: none !important;
		box-shadow: 0 10px 18px rgba(0,0,0,0.11) !important;
	}

	.services-section .card-img-wrap {
		height: 250px !important;
		flex: 0 0 250px;
		overflow: hidden;
	}

	.services-section .card-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.services-section .service-card:hover .card-img {
		transform: none !important;
	}

	.services-section .card-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 1.55rem 1.65rem 1.45rem !important;
	}

	.services-section .card-title {
		margin: 0 0 0.8rem !important;
		color: #111 !important;
		font-family: var(--font-sans);
		font-size: 1.03rem !important;
		font-weight: 800;
		line-height: 1.12;
		letter-spacing: 0 !important;
	}

	.services-section .card-desc {
		margin: 0 !important;
		color: #1f1f1f;
		font-size: 1.125rem !important;
		font-weight: 500;
		line-height: 1.34 !important;
	}

	.services-section .card-link {
		margin-top: auto !important;
		padding-top: 1rem;
		color: #222;
		font-size: 0.82rem !important;
		font-weight: 800;
		letter-spacing: 0 !important;
		text-decoration: none;
	}

	.services-section .card-link:hover {
		color: #0076ba;
	}

	.services-controls {
		display: flex;
		justify-content: center;
		gap: 2rem;
		margin-top: 0.7rem;
	}

	.services-controls button {
		display: grid;
		width: 3rem;
		height: 3rem;
		place-items: center;
		border: 0;
		border-radius: 999px;
		background: #303134;
		color: #fff;
		font-size: 1.7rem;
		font-weight: 400;
		line-height: 1;
		cursor: pointer;
		transition: background 160ms ease, transform 160ms ease;
	}

	.services-arrow-icon {
		width: 1.25rem;
		height: auto;
		pointer-events: none;
	}

	.services-controls button:hover {
		background: #0076ba;
		transform: translateY(-1px);
	}

	@media (max-width: 900px) {
		.services-section {
			padding: 2.15rem 0 1.2rem !important;
		}
		.services-section .container {
			max-width: 100% !important;
			padding-left: 20px !important;
			padding-right: 20px !important;
		}
		.services-section .section-header {
			margin-bottom: 1.25rem !important;
		}
		.services-section .section-header h2 {
			font-size: clamp(2rem, 8vw, 2.6rem) !important;
			white-space: normal !important;
		}
		.services-section .cards-grid {
			gap: 1rem !important;
			padding: 0.3rem 0 1.1rem !important;
		}
		/* Tablet: 2 full cards + a 30%-cut card each side. */
		.services-section .service-card {
			flex: 0 0 calc((100vw - 3 * 1rem) / 3.4) !important;
		}
		.services-controls {
			display: flex !important;
		}
	}

	@media (max-width: 640px) {
		.services-section {
			padding-top: 1.6rem !important;
			padding-bottom: 1.6rem !important;
		}
		.services-section .container {
			padding: 0 18px !important;
		}
		.services-section .section-header {
			margin-bottom: 1rem !important;
		}
		.services-section .section-header h2 {
			font-size: clamp(1.35rem, 6.3vw, 1.65rem) !important;
			line-height: 1.12 !important;
		}
		/* 1-up snapping carousel on mobile */
		.services-carousel {
			width: 100% !important;
			margin-left: 0 !important;
			overflow-x: auto !important;
			scroll-snap-type: x mandatory !important;
			-webkit-overflow-scrolling: touch;
		}
		.services-section .cards-grid {
			display: flex !important;
			flex-direction: row !important;
			width: max-content !important;
			gap: 1rem !important;
			padding: 0.3rem 0 0.75rem !important;
		}
		.services-section .service-card {
			flex: 0 0 calc(100vw - 36px) !important;
			scroll-snap-align: start !important;
		}
		.services-section .card-img-wrap {
			height: 200px !important;
			flex-basis: 200px;
		}
		.services-section .card-body {
			padding: 1.5rem 1.35rem 1.4rem !important;
		}
		.services-controls {
			display: none !important;
		}
		/* Hide the 4 duplicate sets — only real cards (set 2) show */
		.card-dupe {
			display: none !important;
		}
	}
</style>
