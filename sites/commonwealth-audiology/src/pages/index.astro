	<script is:inline>
		document.querySelectorAll("[data-about-slider]").forEach((slider) => {
			const image = slider.querySelector("[data-about-slider-image]");
			const previous = slider.querySelector("[data-about-slider-prev]");
			const next = slider.querySelector("[data-about-slider-next]");
			const slides = JSON.parse(slider.getAttribute("data-about-slider-items") || "[]");
			if (!slides.length || !image || !previous || !next) return;

			let active = 0;
			let timer = null;

			function showSlide(index) {
				active = (index + slides.length) % slides.length;
				image.setAttribute("src", slides[active].src);
				image.setAttribute("alt", slides[active].alt || "");
				slider.setAttribute("data-active-slide", String(active));
			}

			function startAutoSlide() {
				window.clearInterval(timer);
				timer = window.setInterval(showNextSlide, 4000);
			}

			function showNextSlide() {
				showSlide(active + 1);
			}

			function moveSlide(direction) {
				showSlide(active + direction);
				startAutoSlide();
			}

			previous.addEventListener("click", () => moveSlide(-1));
			next.addEventListener("click", () => moveSlide(1));
			slider.addEventListener("mouseenter", () => window.clearInterval(timer));
			slider.addEventListener("mouseleave", startAutoSlide);
			showSlide(0);
			if (slides.length > 1) startAutoSlide();
		});

		// Services carousel JS now lives in ServicesSection.astro.

		document.querySelectorAll("[data-brands-carousel]").forEach((carousel) => {
			const row = carousel.querySelector("[data-brands-row]");
			const previous = carousel.querySelector("[data-brands-prev]");
			const next = carousel.querySelector("[data-brands-next]");
			if (!row || !previous || !next) return;

			function scrollBrands(direction) {
				const item = row.querySelector(".brand-item");
				const gap = parseFloat(getComputedStyle(row).columnGap || "0");
				const step = item ? item.getBoundingClientRect().width + gap : row.clientWidth;
				row.scrollBy({ left: direction * step * 2, behavior: "smooth" });
			}

			previous.addEventListener("click", () => scrollBrands(-1));
			next.addEventListener("click", () => scrollBrands(1));
		});
	</script>

