---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import LocationSection from "../components/LocationSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

const [
	settingsData,
	{ entries: configs, cacheHint },
	{ entries: services },
	{ entries: hearingAids },
	{ entries: team },
	{ entries: testimonials },
	{ entries: faqItems },
	{ entries: protection },
	{ entries: brands },
	{ entries: posts },
] = await Promise.all([
	getSiteSettings(),
	getEmDashCollection("site_config", { limit: 1 }),
	getEmDashCollection("services"),
	getEmDashCollection("hearing_aids"),
	getEmDashCollection("team", { orderBy: { sort_order: "asc" } }),
	getEmDashCollection("testimonials", { limit: 5 }),
	getEmDashCollection("faq"),
	getEmDashCollection("hearing_protection"),
	getEmDashCollection("brands"),
	getEmDashCollection("posts", { orderBy: { published_at: "desc" }, limit: 3 }),
]);

// homepage collection — graceful fallback if collection not yet in DB
let homepages: any[] = [];
try {
	const result = await getEmDashCollection("homepage", { limit: 1 });
	homepages = result.entries;
} catch { /* collection not yet added to DB — use defaults below */ }

Astro.cache.set(cacheHint);

const { siteTitle, siteLogo } = resolveBlogSiteIdentity(settingsData);
const cfg = configs[0]?.data ?? {};
const hp = homepages[0];
const hpCfg = hp?.data ?? {};
const fallbackLogo = "/uploads/0d3a8fc547761a9015ed3bc9284e6d76d16f8417.png";
const logoSrc = siteLogo?.url ?? fallbackLogo;
const logoAlt = siteLogo?.alt || siteTitle;

const phone = cfg.phone ?? "(502) 642-4322";
const bookUrl = cfg.book_url ?? "/book-appointment/";
const heroHeading = hpCfg.hero_heading ?? cfg.hero_heading ?? "Compassionate Hearing Care in Georgetown, KY";
const heroSubtext = hpCfg.hero_subtext ?? cfg.hero_subtext ?? "Hearing care you can trust, for every stage of life.";
const cityLabel = (cfg.city_state ?? "Georgetown, KY").replace(/\s+\d{5}(?:-\d{4})?$/, "");
const defaultAboutText =
	"Life is full of meaningful sounds: laughter with family, conversations with friends, music you love, and the quiet moments that bring calm. When hearing or balance problems begin to interfere, it can feel isolating and overwhelming.\n\nAt Commonwealth Audiology, your hearing wellness is our top priority. Every recommendation we make is shaped by your everyday listening needs and the moments that bring meaning to your life.\n\nOur Doctor of Audiology, Dr. Tiffany Brewer, stays up to date with the latest hearing technology so we can offer you the most effective and innovative options available.\n\nOur care doesn't end when you choose hearing aids. We provide support each step of the way. From helping you adjust to your hearing aids, fine-tuning your device, and making sure they truly support your daily life.";
const aboutTagline = hpCfg.about_tagline
	?? (cfg.about_tagline && cfg.about_tagline !== "AUDIOLOGY EXCELLENCE & PATIENT CARE"
		? cfg.about_tagline
		: `${cityLabel.toUpperCase()} AUDIOLOGISTS & HEARING AIDS`);
const aboutTextSource = hpCfg.about_text ?? cfg.about_text ?? defaultAboutText;
const aboutParagraphs = aboutTextSource.split(/\n\s*\n/).filter(Boolean);
const defaultTeamText =
	"At Commonwealth Audiology, our focus is on restoring clarity, comfort, and confidence so you can fully re-engage with the world around you.\n\nWith expert guidance, clinical excellence, and care tailored to your listening needs, we help you hear and live better each day. Our Georgetown, KY audiologist & team takes the time to understand your goals, your listening environments, and the moments that matter most.";
const teamTextSource = hpCfg.team_text ?? cfg.team_text ?? defaultTeamText;
const teamParagraphs = teamTextSource.split(/\n\s*\n/).filter(Boolean);
const protectionOrder = [
	"Custom Hearing Protection & Ear Molds",
	"Hearing Protection for Musicians",
	"Hearing Protection for Hunters",
];
const hearingAidOrder = [
	"Hearing Aid Selection",
	"Hearing Aid Fittings",
	"Hearing Aid Cleaning & Repair",
	"Hearing Aid Batteries & Accessories",
];
const orderedHearingAids = hearingAids.toSorted((a, b) => {
	const aIndex = hearingAidOrder.indexOf(a.data.title);
	const bIndex = hearingAidOrder.indexOf(b.data.title);
	return (aIndex === -1 ? 99 : aIndex) - (bIndex === -1 ? 99 : bIndex);
});
const displayedHearingAids = orderedHearingAids.slice(0, 4);
const orderedProtection = protection.toSorted((a, b) => {
	const aIndex = protectionOrder.indexOf(a.data.title);
	const bIndex = protectionOrder.indexOf(b.data.title);
	return (aIndex === -1 ? 99 : aIndex) - (bIndex === -1 ? 99 : bIndex);
});
const displayedPosts = posts.slice(0, 2);
/** Featured-image URL for a post (local storage uses meta.storageKey). */
const newsImageUrl = (img: any): string | null => {
	const key = img?.meta?.storageKey;
	if (typeof key === "string" && key) return `/_emdash/api/media/file/${key}`;
	if (typeof img?.src === "string" && img.src) return img.src;
	return null;
};
const formatNewsDate = (d: Date | null | undefined): string =>
	d
		? d.toLocaleDateString("en-US", {
				year: "numeric",
				month: "long",
				day: "numeric",
				timeZone: "UTC",
			})
		: "";
const hearingAidsSubtext =
	(typeof hpCfg.hearing_aids_subtext === "string" && hpCfg.hearing_aids_subtext.trim())
		? hpCfg.hearing_aids_subtext
		: (typeof cfg.hearing_aids_subtext === "string" && cfg.hearing_aids_subtext.trim())
			? cfg.hearing_aids_subtext
			: "Your journey with hearing aids doesn't end once you receive a device; it's just the beginning. We support you every step of the way with personalized fittings, follow-up adjustments, repairs, and ongoing maintenance.";
const seededServicesSubtext =
	"At Commonwealth Audiology, we provide hearing care to meet your every need.";
const servicesSubtext =
	(typeof hpCfg.services_subtext === "string" && hpCfg.services_subtext.trim())
		? hpCfg.services_subtext
		: (typeof cfg.services_subtext === "string" && !cfg.services_subtext.startsWith(seededServicesSubtext))
			? cfg.services_subtext
			: "At Commonwealth Audiology, we believe hearing care is more than a purchase, it's a commitment to your well-being. We offer the following services to make sure you get the best hearing care in Georgetown, KY.";
const orderedServices = services.toSorted((a, b) => Number(a.data.sort_order ?? 0) - Number(b.data.sort_order ?? 0));
const displayedServices = orderedServices.slice(0, 4);
const serviceDescriptions: Record<string, string> = {
	"Hearing Evaluations":
		"We provide comprehensive hearing evaluations to give you a clear and accurate picture of your hearing health. Our testing process looks closely at how you hear different tones, pitches, and speech sounds, helping us identify the type and degree of hearing loss you may be experiencing. Because every individual's needs are unique, we take the time to explain your results, answer your questions, and guide you toward the best next steps.",
	"Hearing Loss Evaluation & Treatment":
		"We take the time to truly understand what you're experiencing and use advanced diagnostic tools to evaluate the health of your inner ear and auditory pathways. From there, we'll walk through your results together and recommend options tailored to your needs and lifestyle, helping you hear more naturally and communicate with confidence.",
	"Ear Wax Removal":
		"Excess ear wax can cause uncomfortable fullness, itching, and even temporary hearing loss, but the good news is, it's an easy fix. We offer safe, gentle removal using professional tools designed to protect your ears (no cotton swabs needed). If you're experiencing blockage, itching, or a sudden drop in hearing, relief can be quick and comfortable.",
	"Tinnitus Evaluations & Treatment":
		"Ringing, buzzing, or humming in the ears can be frustrating, distracting, and exhausting, and you're not alone. We take the time to understand how tinnitus is affecting your day-to-day life and perform a thorough evaluation to identify possible contributing factors, such as hearing changes, noise exposure, or stress. From there, we'll explore personalized, evidence-based options designed to help you find relief and feel more in control.",
};

const fallbackImages = {
	logo: "/uploads/0d3a8fc547761a9015ed3bc9284e6d76d16f8417.png",
	hero: "/uploads/eaf0271580aafaf9040811a8f6e8eb2116fe44e5.jpg",
	building: "/uploads/7f6bb4aabbbd90d0c2e05363bc91c8c3b20a950d.jpg",
	plant: "/uploads/d9d32c8bea0bb36c8812af49a330973e80137a14.png",
	teamGroup: "/uploads/5edd7cf293773c4cbe8f80f5fa3a54d67a2f7acf.jpg",
	tiffany: "/uploads/7854b158e5b131e9a356dfaafa022012ce061557.jpg",
	ashley: "/uploads/6e9f81d4d3d1cc131aee03667f847a44c2b4765e.jpg",
	magnolia: "/uploads/magnolia.jpg?v=1",
	evaluation: "/uploads/454a6991e526dce986ad698d24fbe50e622dd410.jpg",
	loss: "/uploads/987f9e696c6744d636bb6afb18b12cf000eaa426.jpg",
	wax: "/uploads/eed506fc51205e55275e3792962852d28e218d9a.jpg",
	tinnitus: "/uploads/f34a0d4f4c8eea750dd899ef83306ee874cbceb5.jpg",
	selection: "/uploads/card1.jpg",
	fittings: "/uploads/card2.png",
	cleaning: "/uploads/card3.png",
	batteries: "/uploads/card4.png",
	aaa: "/uploads/87ed96a25b1f78845e8de29258ec248d20a201d0.png",
	ada: "/uploads/80f5515bb2d76e90726fdf8cc3a42a785aeb0d9f.png",
	kentucky: "/uploads/b88d47dcf30a2d5545983ee6f70d9f4cfce0ebac.png",
	hearingUp: "/uploads/12edfebb3ce7da80c9aa26852ddab5b3361b0360.png",
	phonak: "/uploads/dfe9fb69662236eb6188ec7c07039422ea88d697.png",
	oticon: "/uploads/f51e125c9dfa276f3f9e87df0e01807b64785421.png",
	widex: "/uploads/33e8f791185fbe867d0d2dbdd67a02dbf5600997.png",
	starkey: "/uploads/ac5e2970d54b324884fd87e8d6ff87dfa695ac4b.png",
	resound: "/uploads/254c5bd985499ce7f69430ddc3b6d99729291867.png",
	unitron: "/uploads/e6811425ab6f2d0ead26b6381c538dbad810cce8.png",
	signia: "/uploads/5aa0c3579ae5acf7a7bba2b4220ab139538fc9f8.png",
};

const brandStripItems = [
	{ name: "Phonak", logo: "/uploads/brand-phonak-tight.png" },
	{ name: "Oticon", logo: "/uploads/brand-oticon-tight.png" },
	{ name: "Widex", logo: "/uploads/brand-widex-tight.png" },
	{ name: "Starkey", logo: "/uploads/brand-starkey-tight.png" },
	{ name: "ReSound GN", logo: "/uploads/brand-resound-tight.png" },
	{ name: "Unitron", logo: "/uploads/brand-unitron-tight.png" },
	{ name: "Signia", logo: "/uploads/brand-signia-tight.png" },
];

const aboutSliderImages = [
	{
		src: "/uploads/7f6bb4aabbbd90d0c2e05363bc9.jpg",
		alt: "Commonwealth Audiology office sign",
	},
	{
		src: "/uploads/676765b59a5714fb6044d267fb3889073a1e9187.jpg",
		alt: "Hearing aid service detail",
	},
	{
		src: "/uploads/5edd7cf293773c4cbe8f80f5fa3a54d67a2f7acf.jpg",
		alt: "Commonwealth Audiology care team",
	},
];

function imageSrc(image: { src?: string } | null | undefined, fallback: string) {
	return image?.src ?? fallback;
}

const serviceImageFallbacks: Record<string, string> = {
	"Hearing Evaluations": fallbackImages.evaluation,
	"Hearing Loss Evaluation & Treatment": fallbackImages.loss,
	"Ear Wax Removal": fallbackImages.wax,
	"Tinnitus Evaluations & Treatment": fallbackImages.tinnitus,
};

function serviceImageSrc(title: string) {
	return serviceImageFallbacks[title] ?? fallbackImages.evaluation;
}

const hearingAidContent: Record<string, { title: string; description: string; image: string }> = {
	"Hearing Aid Selection": {
		title: "Hearing Aid Selection",
		description:
			"Whether you're looking for discreet styles, rechargeable models, Bluetooth connectivity, or enhanced background-noise support, our audiologist will help you choose the device that fits your lifestyle, hearing needs, and budget.",
		image: fallbackImages.selection,
	},
	"Hearing Aid Fittings": {
		title: "Hearing Aid Fittings",
		description:
			"We program and fine-tune your hearing aids using real-ear measurements and personalized adjustments to deliver clear, natural sound tailored to your needs-so you can feel confident and connected in any situation.",
		image: fallbackImages.fittings,
	},
	"Hearing Aid Cleaning & Repair": {
		title: "Hearing Aid Cleaning and Repair",
		description:
			"We provide cleaning, troubleshooting, and repairs to keep your devices comfortable, clear, and dependable-so you can get back to better hearing without delay.",
		image: fallbackImages.cleaning,
	},
	"Hearing Aid Batteries & Accessories": {
		title: "Hearing Aid Batteries and Accessories",
		description:
			"We carry a full range of batteries, cleaning tools, drying kits, chargers, and accessories to keep your devices performing their best.",
		image: fallbackImages.batteries,
	},
};

function hearingAidMeta(title: string) {
	return hearingAidContent[title] ?? {
		title,
		description: "",
		image: fallbackImages.selection,
	};
}

function stars(rating: string | undefined) {
	const n = parseInt(rating ?? "5", 10);
	return "★".repeat(Math.min(5, Math.max(1, n)));
}

---

<Base title="Commonwealth Audiology | Audiologists & Hearing Aids in Georgetown, KY" description="Commonwealth Audiology is an audiology and hearing aid clinic with an expert audiologist providing hearing tests and professional hearing services in Georgetown, KY.">

	<!-- ═══════════════════════════════ HERO ═══════════════════════════════ -->
	<section
		class="hero"
		style={`--hero-bg-img: url('${imageSrc(cfg.hero_image, fallbackImages.hero)}')`}
	>
		<div class="hero-overlay"></div>
		<div class="hero-content">
			<h1 class="hero-heading" {...hp?.edit.hero_heading}>{heroHeading}</h1>
			<p class="hero-subtext" {...hp?.edit.hero_subtext}>{heroSubtext}</p>
			<div class="hero-btns">
				<a href={bookUrl} class="btn-primary">BOOK AN APPOINTMENT <span class="button-arrow" aria-hidden="true"></span></a>
				<a href={`tel:${phone.replace(/\D/g, "")}`} class="btn-outline">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
					CALL US NOW
				</a>
			</div>
		</div>
		<div class="hero-wave">
			<svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="white"/>
			</svg>
		</div>
	</section>

	<!-- ═══════════════════════════════ TRUST BADGES ═══════════════════════════════ -->
	<section class="trust-section">
		<div class="container">
			<div class="trust-badges">
				<div class="trust-badge">
					<img src={fallbackImages.aaa} alt="American Academy of Audiology" />
				</div>
				<div class="trust-badge">
					<img src={fallbackImages.ada} alt="Academy of Doctors of Audiology" />
				</div>
				<div class="trust-badge">
					<img src={fallbackImages.kentucky} alt="Kentucky Academy of Audiology" />
				</div>
				<div class="trust-badge">
					<img src={fallbackImages.hearingUp} alt="HearingUp Network" />
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════ ABOUT ═══════════════════════════════ -->
	<section class="about-section">
		<div class="container">
			<div class="about-grid">
				<div class="about-image-wrap">
					{cfg.about_image?.src
						? <img src={cfg.about_image.src} alt={cfg.about_image.alt ?? "Commonwealth Audiology building"} class="about-img" />
						: <div class="about-img-placeholder"><svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#0076BA" stroke-width="1"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg><p>Upload building photo in Admin → Site Configuration → About Image</p></div>
					}
					<div class="about-slider" data-about-slider data-about-slider-items={JSON.stringify(aboutSliderImages)}>
						<img src={aboutSliderImages[0].src} alt={aboutSliderImages[0].alt} class="about-img about-slider-image" data-about-slider-image />
						<div class="about-slider-controls">
							<button type="button" class="about-slider-arrow about-slider-prev" aria-label="Previous image" data-about-slider-prev>
								<i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
							</button>
							<button type="button" class="about-slider-arrow about-slider-next" aria-label="Next image" data-about-slider-next>
								<i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
							</button>
						</div>
					</div>
				</div>
				<div class="about-content">
					<p class="about-tagline" {...hp?.edit.about_tagline}>{aboutTagline}</p>
					<h2 class="about-heading" {...hp?.edit.about_heading}>{hpCfg.about_heading ?? cfg.about_heading ?? "Commonwealth Audiology"}</h2>
					<div class="about-text" {...hp?.edit.about_text}>
						{aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
					</div>
					<a href={bookUrl} class="btn-primary about-button">BOOK AN APPOINTMENT <span class="button-arrow" aria-hidden="true"></span></a>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════════════════════ TEAM ═══════════════════════════════ -->
	{team.length > 0 && (
		<section class="team-section">
			<div class="container">
				<div class="team-grid">
					<div class="team-intro">
						<h2 {...hp?.edit.team_heading}>{hpCfg.team_heading ?? cfg.team_heading ?? "Meet Your Local Hearing Professionals"}</h2>
						<div class="team-copy" {...hp?.edit.team_text}>
							{teamParagraphs.map((paragraph) => <p>{paragraph}</p>)}
						</div>
						<a href="/tiffany-brewer/" class="link-arrow">MEET THE TEAM <span class="button-arrow" aria-hidden="true"></span></a>
					</div>
					<div class="team-cards">
						{team.map((member) => {
							const photoSrc = member.data.photo?.src
								?? (member.data.name?.toLowerCase().includes("tiffany") ? fallbackImages.tiffany
									: member.data.name?.toLowerCase().includes("aubrey") ? fallbackImages.ashley
									: member.data.name === "Magnolia" ? fallbackImages.magnolia
									: null);
							return (
								<div class="team-card" {...member.edit}>
									{photoSrc
										? <img src={photoSrc} alt={member.data.name} class="team-photo" {...member.edit.photo} />
										: <div class="team-photo-placeholder">{member.data.name.split(" ").map((n: string) => n[0]).join("").slice(0,2)}</div>
									}
									<p class="team-name" {...member.edit.name}>{member.data.name}</p>
									{member.data.role && <p class="team-role" {...member.edit.role}>{member.data.role}</p>}
								</div>
							);
						})}
					</div>
				</div>
			</div>
		</section>
	)}

	<!-- ═══════════════════════════════ LOCATION ═══════════════════════════════ -->
	<LocationSection />

	<!-- ═══════════════════════════════ SERVICES ═══════════════════════════════ -->
	<ServicesSection />

	<!-- ═══════════════════════════════ HEARING AIDS ═══════════════════════════════ -->
	{displayedHearingAids.length > 0 && (
		<section class="hearing-aids-section">
			<div class="container">
				<div class="section-header">
					<h2 {...hp?.edit.hearing_aids_heading}>{hpCfg.hearing_aids_heading ?? cfg.hearing_aids_heading ?? "Hearing Aids & Hearing Aid Services"}</h2>
					<p class="section-subtext" {...hp?.edit.hearing_aids_subtext}>{hearingAidsSubtext}</p>
				</div>
				<div class="ha-grid">
					{displayedHearingAids.map((item) => (
						<div class="ha-card">
							<div class="ha-img-wrap">
								<img src={imageSrc(item.data.image, hearingAidMeta(item.data.title).image)} alt={item.data.image?.alt ?? hearingAidMeta(item.data.title).title} class="ha-img" />
							</div>
							<div class="ha-body">
								<h3 class="ha-title">{hearingAidMeta(item.data.title).title}</h3>
								<p class="ha-desc">{hearingAidMeta(item.data.title).description || item.data.description}</p>
								{item.data.link_url && <a href={item.data.link_url} class="card-link">LEARN MORE <span class="button-arrow" aria-hidden="true"></span></a>}
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- ═══════════════════════════════ BRANDS ═══════════════════════════════ -->
	{brandStripItems.length > 0 && (
		<section class="brands-section">
			<div class="container">
				<h3 class="brands-heading">Supported Hearing Aid Brands</h3>
				<div class="brands-carousel" data-brands-carousel>
					<button type="button" class="brands-arrow brands-arrow-prev" aria-label="Previous brand" data-brands-prev>
						<span class="brands-arrow-icon brands-arrow-left" aria-hidden="true"></span>
					</button>
					<div class="brands-row" data-brands-row>
						{brandStripItems.map((brand) => (
							<div class="brand-item">
								<img src={brand.logo} alt={brand.name} class="brand-logo" />
							</div>
						))}
					</div>
					<button type="button" class="brands-arrow brands-arrow-next" aria-label="Next brand" data-brands-next>
						<span class="brands-arrow-icon brands-arrow-right" aria-hidden="true"></span>
					</button>
				</div>
			</div>
		</section>
	)}

	<!-- ═══════════════════════════════ HEARING PROTECTION ═══════════════════════════════ -->
	{protection.length > 0 && (
		<section class="protection-section">
			<div class="container">
				<div class="section-header">
					<h2 {...hp?.edit.protection_heading}>{hpCfg.protection_heading ?? cfg.protection_heading ?? "Hearing Protection Solutions"}</h2>
					{(hpCfg.protection_subtext || cfg.protection_subtext) && <p class="section-subtext" {...hp?.edit.protection_subtext}>{hpCfg.protection_subtext ?? cfg.protection_subtext}</p>}
				</div>
				<div class="accordion">
					{orderedProtection.map((item) => (
						<div class="accordion-item protection-row">
							<div class="accordion-summary">
								<span class="accordion-title">{item.data.title}</span>
							</div>
							<div class="accordion-body">
								{item.data.description && <p>{item.data.description}</p>}
							</div>
							<span class="protection-arrow button-arrow" aria-hidden="true"></span>
						</div>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- ═══════════════════════════════ TESTIMONIALS ═══════════════════════════════ -->
	{testimonials.length > 0 && (
		<section class="testimonials-section">
			<div class="container">
				<h2 class="testimonials-heading" {...hp?.edit.testimonials_heading}>{hpCfg.testimonials_heading ?? cfg.testimonials_heading ?? "What Our Patients Are Saying"}</h2>
				<div class="testimonials-grid">
					{testimonials.map((t) => (
						<div class="testimonial-card">
							<div class="testimonial-top">
								<div class="testimonial-avatar">
									{t.data.avatar?.src
										? <img src={t.data.avatar.src} alt={t.data.patient_name} />
