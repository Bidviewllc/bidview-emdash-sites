---
/**
 * News & Articles archive — blog index.
 * Base + PageHero (consistent with internal pages) + a full-width card grid.
 */
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";

const { entries: posts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
});

const formatDate = (date?: Date | null) =>
	date
		? date.toLocaleDateString("en-US", {
				year: "numeric",
				month: "long",
				day: "numeric",
				timeZone: "UTC",
			})
		: "";
---

<Base
	title="News & Articles"
	description="Explore the latest hearing health tips, company updates, and industry news from Commonwealth Audiology."
>
	<PageHero
		title="News & Articles"
		breadcrumbs={[{ label: "Home", href: "/" }, { label: "News & Articles" }]}
		image="/uploads/internal-hero-default.png"
		subtitle="Explore the latest hearing health tips, company updates, and industry news to stay informed and connected."
	/>

	<section class="news-archive">
		<div class="news-archive-inner">
			{
				posts.length === 0 ? (
					<p class="news-empty">No articles have been published yet.</p>
				) : (
					<div class="news-archive-grid">
						{posts.map((post) => (
							<a href={`/news/${post.id}/`} class="news-archive-card">
								<div class="news-archive-img">
									{post.data.featured_image ? (
										<Image image={post.data.featured_image} />
									) : (
										<div class="news-archive-img-fallback" />
									)}
								</div>
								<div class="news-archive-body">
									<p class="news-archive-meta">
										<img
											src="/uploads/calendar.svg"
											alt=""
											aria-hidden="true"
										/>
										{formatDate(post.data.publishedAt)}
									</p>
									<h3 class="news-archive-title">{post.data.title}</h3>
									{post.data.excerpt && (
										<p class="news-archive-excerpt">{post.data.excerpt}</p>
									)}
									<span class="news-archive-link">
										READ MORE
										<span class="button-arrow" aria-hidden="true" />
									</span>
								</div>
							</a>
						))}
					</div>
				)
			}
		</div>
	</section>
</Base>

<style>
	.news-archive {
		background: #fff;
		padding: 4rem 1.5rem 5.5rem;
	}

	.news-archive-inner {
		max-width: 1200px;
		margin: 0 auto;
	}

	.news-archive-head {
		text-align: center;
		max-width: 640px;
		margin: 0 auto 3rem;
	}

	.news-archive-head h2 {
		margin: 0 0 0.85rem;
		font-family: "Merriweather", Georgia, "Times New Roman", serif;
		font-size: clamp(1.9rem, 3.4vw, 2.6rem);
		font-weight: 700;
		line-height: 1.2;
		color: #1f1f1f;
	}

	.news-archive-head p {
		margin: 0;
		font-size: 1.08rem;
		line-height: 1.55;
		color: #555;
	}

	.news-empty {
		text-align: center;
		color: #666;
		font-size: 1.1rem;
	}

	.news-archive-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	.news-archive-card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border-radius: 14px;
		overflow: hidden;
		text-decoration: none;
		outline: 1px solid rgba(49, 96, 159, 0.18);
		outline-offset: -1px;
		box-shadow: 0 8px 22px rgba(0, 0, 0, 0.06);
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease;
	}

	.news-archive-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 14px 30px rgba(0, 0, 0, 0.12);
	}

	.news-archive-img {
		aspect-ratio: 8 / 5;
		overflow: hidden;
		background: #e9eef3;
	}

	.news-archive-img :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.news-archive-img-fallback {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #d4e4f0, #b9d2e6);
	}

	.news-archive-body {
		display: flex;
		flex-direction: column;
		flex: 1;
		padding: 1.5rem 1.6rem 1.7rem;
	}

	.news-archive-meta {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		margin: 0 0 0.7rem;
		font-size: 0.88rem;
		font-weight: 600;
		color: #0076ba;
	}

	.news-archive-meta img {
		width: 15px;
		height: 15px;
	}

	.news-archive-title {
		margin: 0 0 0.65rem;
		font-family: "Merriweather", Georgia, "Times New Roman", serif;
		font-size: 1.32rem;
		font-weight: 700;
		line-height: 1.3;
		color: #1f1f1f;
	}

	.news-archive-card:hover .news-archive-title {
		color: #0076ba;
	}

	.news-archive-excerpt {
		margin: 0 0 1.2rem;
		font-size: 1rem;
		line-height: 1.55;
		color: #555;
	}

	.news-archive-link {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		margin-top: auto;
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: #0076ba;
	}

	.news-archive-link .button-arrow {
		width: 1rem;
		height: 0.6875rem;
		background: currentColor;
		-webkit-mask: url("/uploads/right-aerow-button.svg") center / contain
			no-repeat;
		mask: url("/uploads/right-aerow-button.svg") center / contain no-repeat;
	}

	@media (max-width: 900px) {
		.news-archive-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 600px) {
		.news-archive {
			padding: 2.8rem 1.1rem 3.8rem;
		}

		.news-archive-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}
</style>
