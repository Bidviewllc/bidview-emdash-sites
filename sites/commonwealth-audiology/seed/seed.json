					]
				}
			},
			{
				"id": "post-3",
				"slug": "tinnitus-causes-symptoms-treatment",
				"status": "published",
				"data": {
					"title": "Tinnitus: Causes, Symptoms, and Treatment Options",
					"excerpt": "Ringing in the ears affects millions of Americans. Learn what causes tinnitus and how it can be treated.",
					"featured_image": {
						"$media": {
							"url": "https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=1200&h=800&fit=crop",
							"alt": "Person experiencing tinnitus",
							"filename": "tinnitus-treatment.jpg"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Tinnitus — the perception of ringing, buzzing, hissing, or other sounds in the ears — affects an estimated 50 million Americans. While it can be distressing, many effective management strategies are available."
								}
							]
						},
						{
							"_type": "block",
							"style": "h2",
							"children": [
								{
									"_type": "span",
									"text": "Common causes of tinnitus"
								}
							]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Tinnitus can be caused by noise-induced hearing loss, age-related hearing loss, ear infections, earwax blockage, certain medications, or other medical conditions. Identifying the underlying cause is the first step to effective treatment."
								}
							]
						}
					]
				},
