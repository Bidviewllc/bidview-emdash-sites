		"posts": [
			{
				"id": "post-1",
				"slug": "signs-you-need-hearing-test",
				"status": "published",
				"data": {
					"title": "5 Signs You May Need a Hearing Test",
					"excerpt": "Hearing loss often develops gradually. Here are the key signs to watch for and when to schedule your evaluation.",
					"featured_image": {
						"$media": {
							"url": "https://images.unsplash.com/photo-1559051668-e1fa58f25786?w=1200&h=800&fit=crop",
							"alt": "Audiologist performing a hearing test",
							"filename": "hearing-test-signs.jpg"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Hearing loss often develops so gradually that many people don't notice it until it begins significantly affecting their daily life. Knowing the warning signs can help you seek care before the problem worsens."
								}
							]
						},
						{
							"_type": "block",
							"style": "h2",
							"children": [
								{
									"_type": "span",
									"text": "1. Asking people to repeat themselves"
								}
							]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "If you frequently ask friends, family, or coworkers to repeat what they've said, this is one of the most common early signs of hearing loss. It may be happening more than you realize."
								}
							]
						},
						{
							"_type": "block",
							"style": "h2",
							"children": [
								{
									"_type": "span",
									"text": "2. Difficulty hearing in noisy environments"
								}
							]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Struggling to follow conversations in restaurants, social gatherings, or other noisy places is a hallmark sign of hearing difficulty. Background noise can be especially challenging for people with hearing loss."
								}
							]
						}
					]
				},
