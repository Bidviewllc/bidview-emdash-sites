	"content": {
		"site_config": [
			{
				"id": "config-main",
				"slug": "main",
				"status": "published",
				"data": {
					"phone": "(844) 442-4222",
					"address_line1": "201 Believe Lane, Suite B",
					"address_line2": "",
					"city_state": "Georgetown, KY 40324",
					"email": "info@commonwealthaudiology.com",
					"book_url": "/book-appointment/",
					"hero_heading": "Compassionate hearing care that feels like home.",
					"hero_subtext": "Hearing care you can trust, for every stage of life.",
					"about_tagline": "AUDIOLOGY EXCELLENCE & PATIENT CARE",
					"about_heading": "Commonwealth Audiology",
					"about_text": "Life is full of meaningful sounds: laughter with loved ones, conversations with friends, music you love, and the world sounds all around you. When this changes, it can feel isolating, but we're here to help. At Commonwealth Audiology, your hearing wellness is our top priority. Every recommendation we make is shaped by what functions for your specific lifestyle needs and the life you love to live. Our Doctor of Audiology, Dr. Tiffany Brown, stays up to date with the latest hearing technology to ensure you receive the most effective and innovative care available.",
					"team_heading": "Meet Your Local Hearing Professionals",
					"team_text": "At Commonwealth Audiology, our focus is on restoring clarity, comfort, and confidence so you can fully participate in the world around you. With superior guidance, clinical excellence, and care centered on you, we partner with our patients and their families each and every day.",
					"hours_mon": "9:00am - 5:00pm",
					"hours_tue": "9:00am - 5:00pm",
					"hours_wed": "9:00am - 5:00pm",
					"hours_thu": "9:00am - 5:00pm",
					"hours_fri": "9:00am - 5:00pm",
					"hours_sat": "9:00am - 1:00pm",
					"hours_sun": "Closed",
					"map_embed_url": "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3134!2d-84.5603!3d38.2098!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzjCsDEyJzM1LjMiTiA4NMKwMzMnMzcuMSJX!5e0!3m2!1sen!2sus!4v1234567890",
					"services_heading": "Audiology Services in Georgetown, KY",
					"services_subtext": "At Commonwealth Audiology, we provide hearing care to meet your every need. It's our commitment to make sure you can hear every moment clearly.",
					"hearing_aids_heading": "Hearing Aids & Hearing Aid Services",
					"hearing_aids_subtext": "We provide best-in-class hearing aid solutions with expert fittings, adjustments, repairs, and ongoing maintenance so you can hear your best every day.",
					"protection_heading": "Hearing Protection Solutions in Georgetown, KY",
					"protection_subtext": "For anyone exposed to loud noise, custom ear protection offers the safest and most comfortable way to preserve your hearing.",
					"testimonials_heading": "What Our Patients Are Saying",
					"faq_heading": "Frequently Asked Questions",
					"news_heading": "News & Articles",
					"footer_tagline": "Compassionate hearing care in Georgetown, KY. Helping you hear every meaningful moment of life."
				}
			}
		],
