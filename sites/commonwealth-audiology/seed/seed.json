			{
				"id": "post-2",
				"slug": "modern-hearing-aids-technology",
				"status": "published",
				"data": {
					"title": "How Modern Hearing Aid Technology Has Changed Lives",
					"excerpt": "Today's hearing aids are more advanced than ever — smaller, smarter, and connected. Here's what you need to know.",
					"featured_image": {
						"$media": {
							"url": "https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=1200&h=800&fit=crop",
							"alt": "Modern hearing aid technology",
							"filename": "hearing-aid-technology.jpg"
						}
					},
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "The hearing aids of today bear little resemblance to the bulky, whistling devices of decades past. Modern hearing aids are sleek, nearly invisible, and packed with technology that adapts to your environment in real time."
								}
							]
						},
						{
							"_type": "block",
							"style": "h2",
							"children": [
								{
									"_type": "span",
									"text": "Bluetooth connectivity"
								}
							]
						},
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Most modern hearing aids can connect directly to smartphones, TVs, and other Bluetooth devices. This means you can stream phone calls, music, and audio directly to your hearing aids."
								}
							]
						}
					]
				},
				"bylines": [
					{
