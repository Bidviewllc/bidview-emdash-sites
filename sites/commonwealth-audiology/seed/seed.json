		"faq": [
			{
				"id": "faq-1",
				"slug": "how-do-i-know-if-i-need-hearing-aid",
				"status": "published",
				"data": {
					"question": "How do I know if I need a hearing aid?",
					"answer": "If you frequently ask people to repeat themselves, have difficulty hearing in noisy environments, or find yourself turning up the TV volume, it may be time for a hearing evaluation. Schedule an appointment with our audiologist for a comprehensive assessment.",
					"sort_order": "1"
				}
			},
			{
				"id": "faq-2",
				"slug": "are-hearing-aids-covered-by-insurance",
				"status": "published",
				"data": {
					"question": "Are hearing aids covered by insurance?",
					"answer": "Coverage varies by insurance plan. Many plans offer partial coverage for hearing aids. Our team can help you understand your benefits and explore financing options to make hearing care accessible for you.",
					"sort_order": "2"
				}
			},
			{
				"id": "faq-3",
				"slug": "how-often-should-i-get-hearing-test",
				"status": "published",
				"data": {
					"question": "How often should I get a hearing test?",
					"answer": "Adults should have their hearing tested every 3-5 years, or more frequently if you notice changes. Those with existing hearing loss or high noise exposure should be tested annually.",
					"sort_order": "3"
				}
			},
			{
				"id": "faq-4",
				"slug": "can-i-get-hearing-aid-without-fitting",
				"status": "published",
				"data": {
					"question": "Can I get a hearing aid without a fitting?",
					"answer": "A professional fitting is essential for optimal hearing aid performance. Proper fitting ensures the device is programmed correctly for your specific hearing loss, fits comfortably, and delivers the best possible sound quality.",
					"sort_order": "4"
				}
			},
			{
				"id": "faq-5",
				"slug": "how-can-hearing-aids-help-with-tinnitus",
				"status": "published",
				"data": {
					"question": "How can hearing aids help with tinnitus?",
					"answer": "Many modern hearing aids include tinnitus masking features that produce soothing sounds to reduce the perception of ringing. Combined with hearing amplification, they can significantly improve quality of life for tinnitus sufferers.",
					"sort_order": "5"
				}
			}
		],
