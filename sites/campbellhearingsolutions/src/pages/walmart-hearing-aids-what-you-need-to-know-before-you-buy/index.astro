---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/walmart-hearing-aids-what-you-need-to-know-before-you-buy/");

if (!page) {
  throw new Error("Missing dynamic page data for /walmart-hearing-aids-what-you-need-to-know-before-you-buy/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
