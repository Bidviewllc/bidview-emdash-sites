---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/ear-candles-what-you-need-to-know/");

if (!page) {
  throw new Error("Missing dynamic page data for /ear-candles-what-you-need-to-know/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
