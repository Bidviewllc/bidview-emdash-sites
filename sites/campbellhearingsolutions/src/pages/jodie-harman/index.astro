---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/jodie-harman/");

if (!page) {
  throw new Error("Missing dynamic page data for /jodie-harman/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
