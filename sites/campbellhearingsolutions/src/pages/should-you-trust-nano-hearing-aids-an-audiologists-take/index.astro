---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/should-you-trust-nano-hearing-aids-an-audiologists-take/");

if (!page) {
  throw new Error("Missing dynamic page data for /should-you-trust-nano-hearing-aids-an-audiologists-take/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
