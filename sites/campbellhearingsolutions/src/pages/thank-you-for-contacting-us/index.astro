---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/thank-you-for-contacting-us/");

if (!page) {
  throw new Error("Missing dynamic page data for /thank-you-for-contacting-us/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
