---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/understanding-pressure-in-the-ear-causes-treatments-and-when-to-seek-help/");

if (!page) {
  throw new Error("Missing dynamic page data for /understanding-pressure-in-the-ear-causes-treatments-and-when-to-seek-help/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
