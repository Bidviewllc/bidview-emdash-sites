---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/best-way-to-clean-ears/");

if (!page) {
  throw new Error("Missing dynamic page data for /best-way-to-clean-ears/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
