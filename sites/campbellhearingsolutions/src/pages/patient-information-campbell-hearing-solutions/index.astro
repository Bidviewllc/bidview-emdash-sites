---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/patient-information-campbell-hearing-solutions/");

if (!page) {
  throw new Error("Missing dynamic page data for /patient-information-campbell-hearing-solutions/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
