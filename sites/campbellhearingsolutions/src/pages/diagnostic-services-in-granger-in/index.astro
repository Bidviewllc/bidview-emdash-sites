---
import Base from "../../layouts/Base.astro";
import { getPageByRoute } from "../../lib/pages.js";

export const cacheHint = 3600;

const page = await getPageByRoute("/diagnostic-services-in-granger-in/");

if (!page) {
  throw new Error("Missing dynamic page data for /diagnostic-services-in-granger-in/");
}
---

<Base {...page}>
  <Fragment set:html={page.bodyHtml} />
</Base>
