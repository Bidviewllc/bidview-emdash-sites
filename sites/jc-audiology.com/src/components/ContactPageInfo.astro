---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";

const { entry: contactEntry, cacheHint: contactCacheHint } = await getEmDashEntry("contact_page", "contact");
if (contactCacheHint) Astro.cache.set(contactCacheHint);
const { entry: officeEntry, cacheHint: officeCacheHint } = await getEmDashEntry("site_cta_office_info", "jc-audiology-office");
if (officeCacheHint) Astro.cache.set(officeCacheHint);
const { entry: homepageEntry, cacheHint: homepageCacheHint } = await getEmDashEntry("homepage", "home");
if (homepageCacheHint) Astro.cache.set(homepageCacheHint);

const contentBody = Array.isArray(contactEntry?.data?.content_body) ? contactEntry.data.content_body : [];
const office = officeEntry?.data ?? {};
const phone = String(office.phone ?? "(813) 851-2311");
const phoneHref = `tel:${phone.replace(/[^0-9+]/g, "")}`;
const address = String(office.address ?? "1519 Dale Mabry Hwy Suite 105 Lutz FL 33548");
const hours = String(office.hours ?? "Monday - Friday, 9am-5pm");
const mapQuery = String(office.map_query ?? `JC Audiology ${address}`);
const encodedMapQuery = encodeURIComponent(mapQuery);
const directionsLink = `https://www.google.com/maps/search/?api=1&query=${encodedMapQuery}`;
const mapSrc = `https://maps.google.com/maps?q=${encodedMapQuery}&t=m&z=17&output=embed&iwloc=near`;
const appointmentUrl = String(homepageEntry?.data?.appointment_cta_url ?? "/schedule-appointment/");
---

<div class="astro-element astro-element-3d6215e e-con-full e-flex e-con e-child" data-id="3d6215e" data-source-section="homepage:a14cb86" data-element_type="container" data-e-type="container">
  <div class="astro-element astro-element-396a925 astro-widget astro-widget-heading" data-id="396a925" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default">
    <div class="astro-heading-title astro-size-default">
      {contentBody.length > 0 ? <PortableText value={contentBody} /> : "Better Hearing Starts Here - Call or visit JC Audiology in Lutz, FL!"}
    </div>
  </div>
  <div class="astro-element astro-element-02db1a3 astro-widget astro-widget-heading" data-id="02db1a3" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default">
    <div class="astro-heading-title astro-size-default">We are located in:</div>
  </div>
  <div class="astro-element astro-element-a7a7de9 e-con-full e-flex e-con e-child" data-id="a7a7de9" data-element_type="container" data-e-type="container">
    <div class="astro-element astro-element-80a0cf9 e-con-full e-flex e-con e-child" data-id="80a0cf9" data-element_type="container" data-e-type="container">
      <div class="astro-element astro-element-e1a1758 astro-view-stacked astro-shape-circle astro-widget astro-widget-icon" data-id="e1a1758" data-element_type="widget" data-e-type="widget" data-widget_type="icon.default"><div class="astro-icon-wrapper"><div class="astro-icon"><svg aria-hidden="true" class="e-font-icon-svg e-fas-phone-alt" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M497.39 361.8l-112-48a24 24 0 0 0-28 6.9l-49.6 60.6A370.66 370.66 0 0 1 130.6 204.11l60.6-49.6a23.94 23.94 0 0 0 6.9-28l-48-112A24.16 24.16 0 0 0 122.6.61l-104 24A24 24 0 0 0 0 48c0 256.5 207.9 464 464 464a24 24 0 0 0 23.4-18.6l24-104a24.29 24.29 0 0 0-14.01-27.6z"></path></svg></div></div></div>
      <div class="astro-element astro-element-f268552 e-con-full e-flex e-con e-child" data-id="f268552" data-element_type="container" data-e-type="container"><div class="astro-element astro-element-dcaa179 astro-widget astro-widget-heading" data-id="dcaa179" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default">Phone</div></div><div class="astro-element astro-element-d7c90df astro-widget astro-widget-heading" data-id="d7c90df" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default"><a href={phoneHref}>{phone}</a></div></div></div>
    </div>
    <div class="astro-element astro-element-4d11e28 e-con-full e-flex e-con e-child" data-id="4d11e28" data-element_type="container" data-e-type="container">
      <div class="astro-element astro-element-32067b5 astro-view-stacked astro-shape-circle astro-widget astro-widget-icon" data-id="32067b5" data-element_type="widget" data-e-type="widget" data-widget_type="icon.default"><div class="astro-icon-wrapper"><div class="astro-icon"><svg aria-hidden="true" class="e-font-icon-svg e-fas-map-marker-alt" viewBox="0 0 384 512" xmlns="http://www.w3.org/2000/svg"><path d="M172.268 501.67C26.97 291.031 0 269.413 0 192 0 85.961 85.961 0 192 0s192 85.961 192 192c0 77.413-26.97 99.031-172.268 309.67-9.535 13.774-29.93 13.773-39.464 0zM192 272c44.183 0 80-35.817 80-80s-35.817-80-80-80-80 35.817-80 80 35.817 80 80 80z"></path></svg></div></div></div>
      <div class="astro-element astro-element-bc5fdb8 e-con-full e-flex e-con e-child" data-id="bc5fdb8" data-element_type="container" data-e-type="container"><div class="astro-element astro-element-031e0d1 astro-widget astro-widget-heading" data-id="031e0d1" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default">Address</div></div><div class="astro-element astro-element-fa0f508 astro-widget astro-widget-heading" data-id="fa0f508" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default"><a href={directionsLink} target="_blank" rel="noopener">{address}</a></div></div></div>
    </div>
    <div class="astro-element astro-element-1efff1c e-con-full e-flex e-con e-child" data-id="1efff1c" data-element_type="container" data-e-type="container">
      <div class="astro-element astro-element-9826eaf astro-view-stacked astro-shape-circle astro-widget astro-widget-icon" data-id="9826eaf" data-element_type="widget" data-e-type="widget" data-widget_type="icon.default"><div class="astro-icon-wrapper"><div class="astro-icon"><svg aria-hidden="true" class="e-font-icon-svg e-fas-clock" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"></path></svg></div></div></div>
      <div class="astro-element astro-element-18d0333 e-con-full e-flex e-con e-child" data-id="18d0333" data-element_type="container" data-e-type="container"><div class="astro-element astro-element-3664636 astro-widget astro-widget-heading" data-id="3664636" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default">Business Hours</div></div><div class="astro-element astro-element-80055b5 astro-widget astro-widget-heading" data-id="80055b5" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default">{hours}</div></div></div>
    </div>
  </div>
  <div class="astro-element astro-element-e58a3e6 astro-widget astro-widget-template" data-id="e58a3e6" data-element_type="widget" data-e-type="widget" data-widget_type="template.default">
    <div class="astro-widget-container"><div class="astro-template"><div data-astro-type="container" data-astro-id="4407" class="astro astro-4407" data-astro-post-type="astro_library"><div class="astro-element astro-element-6b58007 e-con-full e-flex e-con e-parent" data-id="6b58007" data-element_type="container" data-e-type="container"><div class="astro-element astro-element-80af31e astro-mobile-align-justify astro-widget astro-widget-button" data-id="80af31e" data-element_type="widget" data-e-type="widget" data-widget_type="button.default"><a class="astro-button astro-button-link astro-size-sm" href={appointmentUrl}><span class="astro-button-content-wrapper"><span class="astro-button-icon"><i aria-hidden="true" class="fas fa-arrow-right-long local-fa-arrow-right-long"></i></span><span class="astro-button-text">Schedule Your Appointment</span></span></a></div></div></div></div></div>
  </div>
  <div class="astro-element astro-element-60997f4 astro-widget astro-widget-google_maps" data-id="60997f4" data-element_type="widget" data-e-type="widget" data-widget_type="google_maps.default">
    <div class="astro-custom-embed"><iframe loading="lazy" src={mapSrc} title="JC Audiology" aria-label="Map to JC Audiology" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe></div>
  </div>
</div>
