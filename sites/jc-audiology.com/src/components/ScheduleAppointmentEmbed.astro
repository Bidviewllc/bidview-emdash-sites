---
import { getEmDashEntry } from "emdash";

const { entry, cacheHint } = await getEmDashEntry("schedule_appointment_page", "schedule-appointment");
if (cacheHint) Astro.cache.set(cacheHint);
const schedulerEmbed = String(entry?.data?.scheduler_embed ?? `<iframe id="ceschedule" src="https://www.hearinghealthportal.com/scheduling/schedule.aspx?key=103472-9083&amp;embed=true" width="100%" height="600px" frameborder="0" style="border: 0;"></iframe>`);
---

<div class="astro-element astro-element-eadc933 astro-widget astro-widget-html" data-id="eadc933" data-element_type="widget" data-e-type="widget" data-widget_type="html.default">
  <Fragment set:html={schedulerEmbed} />
  <script src="/assets/js/b60f7f64-ScheduleEmbed-min-v1.js" type="text/javascript"></script>
</div>
