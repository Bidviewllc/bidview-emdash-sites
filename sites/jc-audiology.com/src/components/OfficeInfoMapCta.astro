---
import { getEmDashEntry } from "emdash";

type Props = {
  sectionId?: string;
  sourceSection?: string;
};

const { sectionId = "a14cb86", sourceSection } = Astro.props;
const { entry, cacheHint } = await getEmDashEntry("site_cta_office_info", "jc-audiology-office");
if (cacheHint) Astro.cache.set(cacheHint);

const data = entry?.data ?? {};
const phone = String(data.phone ?? "(813) 851-2311");
const phoneHref = `tel:${phone.replace(/[^0-9+]/g, "")}`;
const address = String(data.address ?? "1519 Dale Mabry Hwy Suite 105 Lutz FL 33548");
const hours = String(data.hours ?? "Monday - Friday, 9am - 5pm");
const ctaText = String(data.cta_text ?? "Schedule Your Appointment");
const ctaLink = String(data.cta_link ?? "/schedule-appointment/");
const mapQuery = String(data.map_query ?? `JC Audiology ${address}`);
const encodedMapQuery = encodeURIComponent(mapQuery);
const directionsLink = `https://www.google.com/maps/search/?api=1&query=${encodedMapQuery}`;
const mapSrc = `https://maps.google.com/maps?q=${encodedMapQuery}&t=m&z=17&output=embed&iwloc=A`;
const rootClass = sectionId === "4b41eeb"
  ? `astro-element astro-element-${sectionId} astro-widget astro-widget-template`
  : `astro-element astro-element-${sectionId} e-con-full e-flex e-con e-child`;
---

<div class={rootClass} data-id={sectionId} data-source-section={sourceSection} data-element_type={sectionId === "4b41eeb" ? "widget" : "container"} data-e-type={sectionId === "4b41eeb" ? "widget" : "container"} data-widget_type={sectionId === "4b41eeb" ? "template.default" : undefined}>
  <div class={sectionId === "4b41eeb" ? "astro-widget-container" : undefined}>
    <div class={sectionId === "4b41eeb" ? "astro-template" : undefined}>
      <div data-astro-type="container" data-astro-id="4476" class="astro astro-4476" data-astro-post-type="astro_library">
        <div class="astro-element astro-element-6d2a6d5 e-flex e-con-boxed e-con e-parent" data-id="6d2a6d5" data-element_type="container" data-e-type="container">
          <div class="e-con-inner">
            <div class="astro-element astro-element-017d2b1 e-con-full e-flex e-con e-child" data-id="017d2b1" data-element_type="container" data-e-type="container">
              <div class="astro-element astro-element-e07fe11 astro-widget astro-widget-google_maps" data-id="e07fe11" data-element_type="widget" data-e-type="widget" data-widget_type="google_maps.default">
                <div class="astro-custom-embed">
                  <iframe loading="lazy" src={mapSrc} title="JC Audiology" aria-label="Map to JC Audiology" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
                </div>
              </div>
            </div>
            <div class="astro-element astro-element-2994219 e-con-full e-flex e-con e-child" data-id="2994219" data-element_type="container" data-e-type="container">
              <div class="astro-element astro-element-19d437a astro-widget astro-widget-heading" data-id="19d437a" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default">
                <h3 class="astro-heading-title astro-size-default" id="our-office">our Office</h3>
              </div>
              <div class="astro-element astro-element-d85245d e-con-full e-flex e-con e-child" data-id="d85245d" data-element_type="container" data-e-type="container">
                <div class="astro-element astro-element-7e33637 e-con-full e-flex e-con e-child" data-id="7e33637" data-element_type="container" data-e-type="container">
                  <div class="astro-element astro-element-403243c astro-view-stacked astro-shape-circle astro-widget astro-widget-icon" data-id="403243c" data-element_type="widget" data-e-type="widget" data-widget_type="icon.default">
                    <div class="astro-icon-wrapper"><div class="astro-icon"><svg aria-hidden="true" class="e-font-icon-svg e-fas-phone-alt" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M497.39 361.8l-112-48a24 24 0 0 0-28 6.9l-49.6 60.6A370.66 370.66 0 0 1 130.6 204.11l60.6-49.6a23.94 23.94 0 0 0 6.9-28l-48-112A24.16 24.16 0 0 0 122.6.61l-104 24A24 24 0 0 0 0 48c0 256.5 207.9 464 464 464a24 24 0 0 0 23.4-18.6l24-104a24.29 24.29 0 0 0-14.01-27.6z"></path></svg></div></div>
                  </div>
                  <div class="astro-element astro-element-63e418b e-con-full e-flex e-con e-child" data-id="63e418b" data-element_type="container" data-e-type="container">
                    <div class="astro-element astro-element-d61bf9e astro-widget astro-widget-heading" data-id="d61bf9e" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default">Phone</div></div>
                    <div class="astro-element astro-element-9cdf365 astro-widget astro-widget-heading" data-id="9cdf365" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default"><a href={phoneHref}>{phone}</a></div></div>
                  </div>
                </div>
                <div class="astro-element astro-element-91054db e-con-full e-flex e-con e-child" data-id="91054db" data-element_type="container" data-e-type="container">
                  <div class="astro-element astro-element-96e6f53 astro-view-stacked astro-shape-circle astro-widget astro-widget-icon" data-id="96e6f53" data-element_type="widget" data-e-type="widget" data-widget_type="icon.default">
                    <div class="astro-icon-wrapper"><div class="astro-icon"><svg aria-hidden="true" class="e-font-icon-svg e-fas-map-marker-alt" viewBox="0 0 384 512" xmlns="http://www.w3.org/2000/svg"><path d="M172.268 501.67C26.97 291.031 0 269.413 0 192 0 85.961 85.961 0 192 0s192 85.961 192 192c0 77.413-26.97 99.031-172.268 309.67-9.535 13.774-29.93 13.773-39.464 0zM192 272c44.183 0 80-35.817 80-80s-35.817-80-80-80-80 35.817-80 80 35.817 80 80 80z"></path></svg></div></div>
                  </div>
                  <div class="astro-element astro-element-e56d9fc e-con-full e-flex e-con e-child" data-id="e56d9fc" data-element_type="container" data-e-type="container">
                    <div class="astro-element astro-element-bfc50f9 astro-widget astro-widget-heading" data-id="bfc50f9" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default">Address</div></div>
                    <div class="astro-element astro-element-f6166d5 astro-widget astro-widget-heading" data-id="f6166d5" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default"><a href={directionsLink} target="_blank" rel="noopener">{address}</a></div></div>
                  </div>
                </div>
                <div class="astro-element astro-element-5a7a822 e-con-full e-flex e-con e-child" data-id="5a7a822" data-element_type="container" data-e-type="container">
                  <div class="astro-element astro-element-da082ae astro-view-stacked astro-shape-circle astro-widget astro-widget-icon" data-id="da082ae" data-element_type="widget" data-e-type="widget" data-widget_type="icon.default">
                    <div class="astro-icon-wrapper"><div class="astro-icon"><svg aria-hidden="true" class="e-font-icon-svg e-fas-clock" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256,8C119,8,8,119,8,256S119,504,256,504,504,393,504,256,393,8,256,8Zm92.49,313h0l-20,25a16,16,0,0,1-22.49,2.5h0l-67-49.72a40,40,0,0,1-15-31.23V112a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V256l58,42.5A16,16,0,0,1,348.49,321Z"></path></svg></div></div>
                  </div>
                  <div class="astro-element astro-element-01484b0 e-con-full e-flex e-con e-child" data-id="01484b0" data-element_type="container" data-e-type="container">
                    <div class="astro-element astro-element-ab07a6e astro-widget astro-widget-heading" data-id="ab07a6e" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default">Business Hours</div></div>
                    <div class="astro-element astro-element-fb7a7ea astro-widget astro-widget-heading" data-id="fb7a7ea" data-element_type="widget" data-e-type="widget" data-widget_type="heading.default"><div class="astro-heading-title astro-size-default">{hours}</div></div>
                  </div>
                </div>
              </div>
              <div class="astro-element astro-element-b28303c e-con-full e-flex e-con e-child" data-id="b28303c" data-element_type="container" data-e-type="container">
                <div class="astro-element astro-element-b87c61e astro-widget astro-widget-template" data-id="b87c61e" data-element_type="widget" data-e-type="widget" data-widget_type="template.default">
                  <div class="astro-widget-container"><div class="astro-template"><div data-astro-type="container" data-astro-id="4407" class="astro astro-4407" data-astro-post-type="astro_library"><div class="astro-element astro-element-6b58007 e-con-full e-flex e-con e-parent" data-id="6b58007" data-element_type="container" data-e-type="container"><div class="astro-element astro-element-80af31e astro-mobile-align-justify astro-widget astro-widget-button" data-id="80af31e" data-element_type="widget" data-e-type="widget" data-widget_type="button.default"><a class="astro-button astro-button-link astro-size-sm" href={ctaLink}><span class="astro-button-content-wrapper"><span class="astro-button-icon"><i aria-hidden="true" class="fas fa-arrow-right-long local-fa-arrow-right-long"></i></span><span class="astro-button-text">{ctaText}</span></span></a></div></div></div></div></div>
                </div>
                <div class="astro-element astro-element-add33d4 astro-align-center astro-mobile-align-justify astro-widget astro-widget-button" data-id="add33d4" data-element_type="widget" data-e-type="widget" data-widget_type="button.default">
                  <a class="astro-button astro-button-link astro-size-sm" href={directionsLink} target="_blank" rel="noopener"><span class="astro-button-content-wrapper"><span class="astro-button-icon"><i aria-hidden="true" class="fas fa-arrow-right-long local-fa-arrow-right-long"></i></span><span class="astro-button-text">Get Directions</span></span></a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
