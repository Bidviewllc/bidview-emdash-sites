---
import { EmDashHead } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import shell from "../_shell.json";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	headExtra?: string;
	bodyClass?: string;
}

const { title, description, image, headExtra = "", bodyClass = "" } = Astro.props;

const siteName = "Florida Medical Hearing";
const fullTitle = title || siteName;
const siteDescription = description || "Expert hearing care, hearing aids, and audiology services in Sebring and Lake Placid, FL.";

const pageCtx = createPublicPageContext({
	Astro,
	kind: "custom",
	pageType: "website",
	title: fullTitle,
	description: siteDescription,
	canonical: `https://floridamedicalhearingaids.com${Astro.url.pathname}`,
	image,
	seo: { ogImage: image },
	siteName,
});
---

<!doctype html>
<html lang="en-US">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{fullTitle}</title>
		<link rel="icon" href="/assets/media/Company-Placeholder-Alt-1-150x100.png" sizes="32x32" />
		<link rel="icon" href="/assets/media/Company-Placeholder-Alt-1-e1759827728687.png" sizes="192x192" />
		<link rel="apple-touch-icon" href="/assets/media/Company-Placeholder-Alt-1-e1759827728687.png" />
		<EmDashHead page={pageCtx} />
		<Fragment set:html={headExtra} />
	</head>
	<body class={bodyClass}>
		<Fragment set:html={shell.header} />
		<slot />
		<Fragment set:html={shell.footer} />
		<Fragment set:html={shell.scripts} />
		<style is:inline set:html={`.e-n-tabs-content > .e-con:not(.e-active){display:none;}`} />
		<script is:inline>
			// Elementor nested-tabs toggle (the widget's own JS isn't bundled in the static build).
			document.querySelectorAll(".e-n-tabs").forEach(function (tabs) {
				var titles = tabs.querySelectorAll(".e-n-tab-title");
				var panels = tabs.querySelectorAll(".e-n-tabs-content > [aria-labelledby]");
				function activate(id) {
					titles.forEach(function (t) {
						var on = t.id === id;
						t.setAttribute("aria-selected", on ? "true" : "false");
						t.classList.toggle("e-active", on);
					});
					panels.forEach(function (p) {
						var on = p.getAttribute("aria-labelledby") === id;
						p.classList.toggle("e-active", on);
						p.style.display = on ? "" : "none";
					});
				}
				titles.forEach(function (t) {
					t.addEventListener("click", function () { activate(t.id); });
					t.addEventListener("keydown", function (e) {
						if (e.key === "Enter" || e.key === " ") { e.preventDefault(); activate(t.id); }
					});
				});
				var sel = tabs.querySelector('.e-n-tab-title[aria-selected="true"]') || titles[0];
				if (sel) activate(sel.id);
			});
		</script>
	</body>
</html>
