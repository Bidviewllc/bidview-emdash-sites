---
import Base from "../layouts/Base.astro";
import { getEntry } from "../content";
export const cacheHint = 3600;
const raw = (Astro.params.slug ?? "").replace(/\/+$/, "");
if (raw === "ear-candling") {
	return Astro.redirect("/ear-candling-risks-why-ear-candles-are-not-a-safe-way-to-remove-wax/", 301);
}
const e = getEntry(raw);
if (!e) return new Response("Not found", { status: 404 });
const d = e.data;
---
<Base title={d.meta_title} description={d.meta_description} image={d.og_image} headExtra={d.head_extra} bodyClass={d.body_class}>
	<Fragment set:html={d.body} />
</Base>
