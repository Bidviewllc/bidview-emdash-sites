---
import "../styles/local/global.css";
import "../styles/local/layout.css";
import "../styles/local/components.css";
import "../styles/local/sections.css";
import "../styles/local/pages/home.css";
import "../styles/local/pages/about.css";
import "../styles/local/pages/internal.css";
import "../styles/local/pages/contact.css";
import "../styles/local/pages/member.css";
import "../styles/local/pages/blog.css";
import "../styles/local/pages/Arvada.css";
import "../styles/local/pages/Littleton.css";
import Preloader from "../components/Preloader.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SiteScripts from "../components/SiteScripts.astro";

const { title = "New Leaf Hearing Care", description = "", canonical, ogType = "website", ogImage } = Astro.props;

// Canonical + absolute URLs derive from the serving origin, so they auto-adjust
// after the custom-domain cutover (workers.dev -> newleafhearing.com).
const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.url.origin).href;
const ogImageUrl = new URL(ogImage || "/assets/og-image.jpg", Astro.url.origin).href;
const ogDescription = description || "Audiology and hearing aid care from trusted audiologists in Arvada and Littleton, Colorado.";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="New Leaf Hearing Care" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" type="image/webp" href="/assets/new-leaf-hearing-care-favicon.webp" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Outfit:wght@500;600&family=Source+Serif+4:opsz,wght@8..60,600&display=swap" rel="stylesheet" />
    <script type="text/javascript" src="https://www.bugherd.com/sidebarv2.js?apikey=npluy9pybrbkeqylzbokpq" async="true" is:inline></script>
  </head>
  <body>
    <Preloader />
    <Header />
    <slot />
    <Footer />
    <SiteScripts />
  </body>
</html>
