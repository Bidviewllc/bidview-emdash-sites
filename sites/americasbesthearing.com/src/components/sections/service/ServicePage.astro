---
import { renderServicePageHtml } from "./service-page-renderer";
import { getEmDashEntry } from "emdash";

interface Props {
	rawHtml: string;
	servicePage: any;
}

const ctaResult = await getEmDashEntry("internal_page_ctas", "default");
const cta = ctaResult.entry;
const htmlWithCta = renderServicePageHtml(Astro.props.rawHtml, Astro.props.servicePage, cta);
---

<Fragment set:html={htmlWithCta} />
