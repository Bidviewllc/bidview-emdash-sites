---
import Base from "../../../layouts/Base.astro";
import { getEmDashCollection } from "emdash";
import HearingAidBrandPage from "../../../components/sections/hearing-aid-brand/HearingAidBrandPage.astro";
import { entryData, findHearingAidBrandPage, hearingAidBrandPageDescription, hearingAidBrandPageTitle } from "../../../components/sections/hearing-aid-brand/hearing-aid-brand-page-renderer";
import contentHtml from "../../../components/raw-pages/hearing-aids__resound.html?raw";

export const cacheHint = 3600;

const brandSlug = "resound";
const routePath = "/hearing-aids/resound/";
const brandPageResult = await getEmDashCollection("hearing_aid_brand_pages", { status: "published" });
const carouselResult = await getEmDashCollection("hearing_aid_brand_carousel_images", { status: "published" });
const modelResult = await getEmDashCollection("hearing_aid_brand_models", { status: "published" });
const faqResult = await getEmDashCollection("hearing_aid_brand_faqs", { status: "published" });
const brandPage = findHearingAidBrandPage(brandPageResult.entries, brandSlug, routePath);
const byBrand = (entry: any) => String(entry?.brand_slug || "") === brandSlug;
const bySort = (a: any, b: any) => Number(a?.sort_order || 0) - Number(b?.sort_order || 0);
const carouselImages = carouselResult.entries.map(entryData).filter(byBrand).sort(bySort);
const models = modelResult.entries.map(entryData).filter(byBrand).sort(bySort);
const faqs = faqResult.entries.map(entryData).filter(byBrand).sort(bySort);
const pageTitle = hearingAidBrandPageTitle(brandPage);
const pageDescription = hearingAidBrandPageDescription(brandPage);
