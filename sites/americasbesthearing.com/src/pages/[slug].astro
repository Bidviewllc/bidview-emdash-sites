---
import Base from "../layouts/Base.astro";
import rawContentHtml from "../components/raw-pages/what-are-the-types-of-hearing-tests.html?raw";
import { getEmDashEntry, getTermsForEntries } from "emdash";
import { renderBlogPostHtml } from "../components/sections/blog-post-renderer";

export const prerender = false;
export const cacheHint = 3600;

const slug = Astro.params.slug || "";
const postResult = slug ? await getEmDashEntry("posts", slug) : { entry: null };
const post = postResult.entry;

if (!post) {
	Astro.response.status = 404;
}

const postCategoryMap = post?.data?.id
	? await getTermsForEntries("posts", [post.data.id], "category")
	: new Map();
const category = post?.data?.id ? postCategoryMap.get(post.data.id)?.[0]?.label || "" : "";
const ctaResult = await getEmDashEntry("internal_page_ctas", "default");
const title = post?.data?.meta_title || (post?.data?.title ? `${post.data.title} | America's Best Hearing` : "Page Not Found | America's Best Hearing");
const description = post?.data?.description || post?.data?.meta_description || "";
const blogTemplateHead =
	'<link rel="stylesheet" id="astro-gf-sourcesans3-css" href="https://fonts.googleapis.com/css?family=Source+Sans+3:100,100italic,200,200italic,300,300italic,400,400italic,500,500italic,600,600italic,700,700italic,800,800italic,900,900italic&display=swap" media="all">' +
	'<link rel="stylesheet" id="astro-gf-sourceserif4-css" href="https://fonts.googleapis.com/css?family=Source+Serif+4:100,100italic,200,200italic,300,300italic,400,400italic,500,500italic,600,600italic,700,700italic,800,800italic,900,900italic&display=swap" media="all">' +
	'<link type="text/css" media="all" href="/assets/styles/breeze_what-are-the-types-of-hearing-tests-1-5152-093b6b94c8.css?v=20260513-static-v1" rel="stylesheet">';
const contentHtml = post
	? renderBlogPostHtml(rawContentHtml, post, category, "", ctaResult.entry)
	: '<main class="site-main"><section class="e-con"><div class="e-con-inner"><h1>Page Not Found</h1><p>The page you are looking for could not be found.</p></div></section></main>';
---

<Base title={title} description={description} bodyClass={"astro-singular post-template-default single single-post single-format-standard astro-custom-logo astro-embed-responsive astro-theme-hello-astro astro-child-theme-hello-theme-child-master hello-astro-default astro-default astro-kit-7 astro-page-1057"} extraHead={blogTemplateHead}>
	<Fragment set:html={contentHtml} />
</Base>
