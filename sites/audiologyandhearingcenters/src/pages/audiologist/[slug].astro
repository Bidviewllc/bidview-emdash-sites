---
export const prerender = false;

import staticHeadHtml from '../../components/audiologist-head-static.html?raw';
import navHtml       from '../../components/audiologist-nav.html?raw';
import tabsHtml      from '../../components/audiologist-tabs.html?raw';
import { env }       from 'cloudflare:workers';

const { slug } = Astro.params;
const db = (env as any).DB;

if (!db) return new Response('DB not available — check Cloudflare bindings', { status: 503 });

const row: any = await db
  .prepare('SELECT * FROM ec_audiologists WHERE slug = ? AND status = ?')
  .bind(slug, 'published')
  .first();

if (!row) return new Response(null, { status: 404 });

const emNum    = (row.em_class || '').replace('em-', '');
const fullName = row.credentials ? `${row.name}, ${row.credentials}` : (row.name || '');
const canonical = `/audiologist/${slug}/`;

function esc(s: string): string {
  return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// Load hero shell for this slug via glob
const shells = import.meta.glob('/src/shells/audiologist/*.html', { query: '?raw', import: 'default' });
const shellKey = `/src/shells/audiologist/${slug}.html`;
const shellLoader = shells[shellKey];
let heroHtml = shellLoader ? String(await shellLoader()) : '';

// Auto-activate the location tab matching this audiologist's clinic.
// Tab order in shells: 1=Alpharetta, 2=Bonita Springs, 3=Ocala, 4=Palm Harbor,
// 5=Sarasota, 6=Tampa Palms, 7=Tampa Westchase, 8=Venice, 9=Naples.
const LOCATION_TAB_INDEX: Record<string, number> = {
  'alpharetta': 1, 'bonita springs': 2, 'ocala': 3, 'palm harbor': 4,
  'sarasota': 5, 'tampa palms': 6, 'tampa westchase': 7, 'venice': 8, 'naples': 9,
};
const locKey = (row.location_label || '').toLowerCase().split(',')[0].trim();
const targetIdx = LOCATION_TAB_INDEX[locKey] || 0;

if (heroHtml) {
  heroHtml = heroHtml
    .replace(/\{\{FULL_NAME\}\}/g, esc(fullName))
    .replace(/\{\{NAME\}\}/g,      esc(row.name || ''))
    .replace(/\{\{TITLE\}\}/g,     esc(row.title || ''))
    .replace(/\{\{LOCATION_URL\}\}/g,   row.location_url || '')
    .replace(/\{\{LOCATION_LABEL\}\}/g, esc(row.location_label || ''))
    .replace(/\{\{BIO\}\}/g,       row.bio || '')
    .replace(/\{\{EM_CLASS\}\}/g,  row.em_class || '')
    .replace(/\{\{PHOTO_SRC\}\}/g, row.photo_src || '')
    .replace(/\{\{PHOTO_ALT\}\}/g, esc(row.photo_alt || row.name || ''));

  if (targetIdx && targetIdx !== 1) {
    // Button attribute order: aria-selected="..." ... data-tab-index="N" ... tabindex="..."
    heroHtml = heroHtml
      .replace(
        /(<button[^>]*?)aria-selected="true"([^>]*?data-tab-index="1"[^>]*?)tabindex="0"/,
        '$1aria-selected="false"$2tabindex="-1"'
      )
      .replace(
        new RegExp(`(<button[^>]*?)aria-selected="false"([^>]*?data-tab-index="${targetIdx}"[^>]*?)tabindex="-1"`),
        '$1aria-selected="true"$2tabindex="0"'
      );
    // Panel: only the active panel has class starting with "e-active "
    heroHtml = heroHtml
      .replace(
        /(<div[^>]*?)class="e-active (em-element [^"]*?)"([^>]*?data-tab-index="1"[^>]*?role="tabpanel")/,
        '$1class="$2"$3'
      )
      .replace(
        new RegExp(`(<div[^>]*?)class="(em-element [^"]*?)"([^>]*?data-tab-index="${targetIdx}"[^>]*?role="tabpanel")`),
        '$1class="e-active $2"$3'
      );
  }
}

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "/#organization",
      "name": "Audiology & Hearing Centers",
      "url": "https://audiologyandhearingcenters.com",
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonical}#breadcrumb`,
      "itemListElement": [
        { "@type": "ListItem", "position": "1", "item": { "@id": "/", "name": "Home" } },
        { "@type": "ListItem", "position": "2", "item": { "@id": canonical, "name": fullName } },
      ],
    },
    {
      "@type": "Person",
      "@id": `${canonical}#physician`,
      "name": row.name,
      "jobTitle": row.title,
      "image": row.photo_src ? {
        "@type": "ImageObject",
        "url": row.photo_src,
        "caption": row.photo_alt || row.name,
      } : undefined,
      "worksFor": { "@id": "/#organization" },
    },
  ],
});

const bodyClass = `wp-singular audiologist-template-default single single-audiologist wp-custom-logo wp-embed-responsive wp-theme-hello-elementor hello-em-default em-default em-kit-21 em-page-${emNum}`;
---
<!doctype html>
<html lang="en-US" prefix="og: https://ogp.me/ns#">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1" name="viewport"/>

<title>{row.meta_title || fullName}</title>
<meta content={row.meta_description || ''} name="description">
<meta content="follow, index, max-snippet:-1, max-video-preview:-1, max-image-preview:large" name="robots">
<link href={canonical} rel="canonical">
<meta content="en_US" property="og:locale"/>
<meta content="article" property="og:type"/>
<meta content={row.meta_title || fullName} property="og:title"/>
<meta content={row.meta_description || ''} property="og:description"/>
<meta content={canonical} property="og:url"/>
<meta content="Audiology & Hearing Centers" property="og:site_name"/>
{row.photo_src && <meta content={row.photo_src} property="og:image"/>}
{row.photo_src && <meta content={row.photo_src} property="og:image:secure_url"/>}
{row.photo_alt && <meta content={row.photo_alt} property="og:image:alt"/>}
<meta content="summary_large_image" name="twitter:card"/>
<meta content={row.meta_title || fullName} name="twitter:title"/>
<meta content={row.meta_description || ''} name="twitter:description"/>
{row.photo_src && <meta content={row.photo_src} name="twitter:image"/>}
<script class="rank-math-schema-pro" type="application/ld+json" set:html={schema}></script>

<Fragment set:html={staticHeadHtml} />
{emNum && <link href={`/assets/css/pages/post-${emNum}.css`} id={`em-post-${emNum}-css`} media="all" rel="stylesheet"/>}
</head>
<body class={bodyClass}>
<Fragment set:html={navHtml} />
<Fragment set:html={heroHtml} />
<Fragment set:html={tabsHtml} />
{targetIdx > 1 && (
  <script is:inline set:html={`
(function(){
  var TARGET_IDX = ${targetIdx};
  function activate() {
    var btn = document.querySelector('button.e-n-tab-title[data-tab-index="' + TARGET_IDX + '"]');
    if (!btn) return false;
    var sel = document.querySelector('button.e-n-tab-title[aria-selected="true"]');
    if (sel && sel === btn) return true;
    btn.click();
    return document.querySelector('button.e-n-tab-title[aria-selected="true"]') === btn;
  }
  // Try once on load, then re-poll for ~3s in case Elementor re-renders the widget.
  function loop(deadline) {
    activate();
    if (Date.now() < deadline) setTimeout(function(){ loop(deadline); }, 200);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function(){ loop(Date.now() + 3000); });
  } else {
    loop(Date.now() + 3000);
  }
})();
`} />
)}
<script is:inline>
(function(){
  function initSmartMenus() {
    if (typeof jQuery === 'undefined' || typeof jQuery.fn.smartmenus === 'undefined') {
      setTimeout(initSmartMenus, 100);
      return;
    }
    var $menus = jQuery('.em-nav-menu:not([data-smartmenus-id])');
    if (!$menus.length) return;
    $menus.smartmenus({
      subIndicators: true,
      subIndicatorsText: '<i class="fas fa-caret-down" aria-hidden="true"></i>',
      subIndicatorsPos: 'append',
      subMenusMaxWidth: '1000px'
    });
  }
  document.addEventListener('DOMContentLoaded', function(){
    var toggles = document.querySelectorAll('.em-menu-toggle, .e-n-menu-toggle, [class*="menu-toggle"]');
    toggles.forEach(function(btn){
      btn.addEventListener('click', function(e){
        e.preventDefault();
        var nav = btn.closest('.em-nav-menu--main') || btn.nextElementSibling || btn.closest('nav');
        if(nav) nav.classList.toggle('em-nav-menu--opened');
        btn.classList.toggle('em-active');
        btn.setAttribute('aria-expanded', btn.classList.contains('em-active') ? 'true' : 'false');
      });
    });
    setTimeout(initSmartMenus, 300);
  });
})();
</script>
</body>
</html>
